@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <a href="/" class="auth-logo">HOANG<span>STORE</span></a>
            <h1 class="auth-title">Đặt lại mật khẩu</h1>
            <p class="auth-subtitle">Tạo mật khẩu mới cho tài khoản của bạn</p>
        </div>

        <div class="auth-body">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-0 py-2" role="alert"></div>
                <input asp-for="Input.Code" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Input.Email" class="auth-label">Email</label>
                    <input asp-for="Input.Email" class="form-control auth-input" autocomplete="username" aria-required="true" placeholder="Nhập email" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="auth-label">Mật khẩu mới</label>
                    <input asp-for="Input.Password" class="form-control auth-input" autocomplete="new-password" aria-required="true" placeholder="Nhập mật khẩu mới" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="auth-label">Xác nhận mật khẩu</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control auth-input" autocomplete="new-password" aria-required="true" placeholder="Nhập lại mật khẩu" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger auth-btn w-100">Đặt lại mật khẩu</button>
            </form>
        </div>
    </div>
</div>

<style>
    .auth-page {
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 12px;
        background: #f7f7f7;
    }

    .auth-card {
        width: 100%;
        max-width: 460px;
        background: #fff;
        border: 1px solid #e5e5e5;
        box-shadow: 0 8px 24px rgba(0,0,0,.06);
    }

        .auth-card.wide {
            max-width: 760px;
        }

    .auth-header {
        padding: 28px 30px 18px;
        border-bottom: 1px solid #eee;
        text-align: center;
    }

    .auth-logo {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: .5px;
        text-decoration: none;
        color: #111;
    }

        .auth-logo span {
            color: #f4b400;
        }

    .auth-title {
        margin: 14px 0 4px;
        font-size: 24px;
        font-weight: 700;
        color: #222;
    }

    .auth-subtitle {
        margin: 0;
        color: #6c757d;
        font-size: 14px;
    }

    .auth-body {
        padding: 26px 30px 30px;
    }

    .auth-label {
        font-weight: 600;
        margin-bottom: 6px;
    }

    .auth-input {
        border-radius: 0;
        min-height: 46px;
    }

        .auth-input:focus {
            border-color: #dc3545;
            box-shadow: 0 0 0 .2rem rgba(220,53,69,.12);
        }

    .auth-btn {
        min-height: 46px;
        border-radius: 0;
        font-weight: 700;
        text-transform: uppercase;
    }

    .auth-links {
        margin-top: 18px;
        text-align: center;
        font-size: 14px;
    }

        .auth-links a {
            color: #dc3545;
            text-decoration: none;
        }

            .auth-links a:hover {
                text-decoration: underline;
            }

    .auth-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 22px 0;
        color: #999;
        font-size: 13px;
    }

        .auth-divider::before, .auth-divider::after {
            content: "";
            height: 1px;
            background: #e5e5e5;
            flex: 1;
        }

    .validation-summary-errors ul {
        margin-bottom: 0;
        padding-left: 18px;
    }

    @@media (max-width: 575.98px) {
        .auth-header {
            padding: 24px 20px 16px;
        }

        .auth-body {
            padding: 22px 20px 26px;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
