@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <a href="/" class="auth-logo">HOANG<span>STORE</span></a>
            <h1 class="auth-title">Đăng nhập</h1>
            <p class="auth-subtitle">Chào mừng bạn quay lại HoangStore</p>
        </div>

        <div class="auth-body">
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-0 py-2" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="auth-label">Email</label>
                    <input asp-for="Input.Email" class="form-control auth-input" autocomplete="username" aria-required="true" placeholder="Nhập email" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="auth-label">Mật khẩu</label>
                    <input asp-for="Input.Password" class="form-control auth-input" autocomplete="current-password" aria-required="true" placeholder="Nhập mật khẩu" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <label class="form-check-label">
                        <input class="form-check-input rounded-0 me-1" asp-for="Input.RememberMe" />
                        Ghi nhớ đăng nhập
                    </label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="text-danger text-decoration-none">Quên mật khẩu?</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-danger auth-btn w-100">Đăng nhập</button>

                <div class="auth-divider">hoặc</div>

                <div class="auth-links mt-0">
                    Chưa có tài khoản?
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold">Đăng ký ngay</a>
                </div>

                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <div class="mt-3">
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-dark rounded-0 w-100 mb-2" name="provider" value="@provider.Name">Đăng nhập bằng @provider.DisplayName</button>
                            }
                        </form>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

<style>
    .auth-page {
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 12px;
        background: #f7f7f7;
    }

    .auth-card {
        width: 100%;
        max-width: 460px;
        background: #fff;
        border: 1px solid #e5e5e5;
        box-shadow: 0 8px 24px rgba(0,0,0,.06);
    }

        .auth-card.wide {
            max-width: 760px;
        }

    .auth-header {
        padding: 28px 30px 18px;
        border-bottom: 1px solid #eee;
        text-align: center;
    }

    .auth-logo {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: .5px;
        text-decoration: none;
        color: #111;
    }

        .auth-logo span {
            color: #f4b400;
        }

    .auth-title {
        margin: 14px 0 4px;
        font-size: 24px;
        font-weight: 700;
        color: #222;
    }

    .auth-subtitle {
        margin: 0;
        color: #6c757d;
        font-size: 14px;
    }

    .auth-body {
        padding: 26px 30px 30px;
    }

    .auth-label {
        font-weight: 600;
        margin-bottom: 6px;
    }

    .auth-input {
        border-radius: 0;
        min-height: 46px;
    }

        .auth-input:focus {
            border-color: #dc3545;
            box-shadow: 0 0 0 .2rem rgba(220,53,69,.12);
        }

    .auth-btn {
        min-height: 46px;
        border-radius: 0;
        font-weight: 700;
        text-transform: uppercase;
    }

    .auth-links {
        margin-top: 18px;
        text-align: center;
        font-size: 14px;
    }

        .auth-links a {
            color: #dc3545;
            text-decoration: none;
        }

            .auth-links a:hover {
                text-decoration: underline;
            }

    .auth-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 22px 0;
        color: #999;
        font-size: 13px;
    }

        .auth-divider::before, .auth-divider::after {
            content: "";
            height: 1px;
            background: #e5e5e5;
            flex: 1;
        }

    .validation-summary-errors ul {
        margin-bottom: 0;
        padding-left: 18px;
    }

    @@media (max-width: 575.98px) {
        .auth-header {
            padding: 24px 20px 16px;
        }

        .auth-body {
            padding: 22px 20px 26px;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
