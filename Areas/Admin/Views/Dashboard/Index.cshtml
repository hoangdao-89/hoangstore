@model hoangstore.Areas.Admin.ViewModels.DashboardViewModel
@using hoangstore.Helpers
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";
    var monthStart = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).ToString("yyyy-MM-dd");
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">Dashboard</h2>
            <p class="text-muted mb-0">Tổng quan kinh doanh, đơn hàng, sản phẩm và tồn kho.</p>
        </div>

        <form action="@Url.Action("ExportRevenuePdf", "Dashboard", new { area = "Admin" })" method="get" class="d-flex flex-wrap align-items-end gap-2">
            <div>
                <label class="form-label small mb-1">Từ ngày</label>
                <input type="date" name="fromDate" value="@monthStart" class="form-control form-control-sm rounded-0" required />
            </div>
            <div>
                <label class="form-label small mb-1">Đến ngày</label>
                <input type="date" name="toDate" value="@today" class="form-control form-control-sm rounded-0" required />
            </div>
            <button class="btn btn-danger btn-sm rounded-0" type="submit"><i class="bi bi-file-earmark-pdf me-1"></i>Xuất PDF</button>
        </form>
    </div>

    <section class="mb-4">
        <h5 class="fw-bold mb-3">Tổng quan kinh doanh</h5>
        <div class="row g-3">
            <div class="col-xl-3 col-md-6"><div class="card border-0 shadow-sm rounded-0 h-100"><div class="card-body"><div class="text-muted">Tổng doanh thu</div><h3 class="fw-bold text-danger mb-0">@Model.TotalRevenue.ToString("N0") đ</h3></div></div></div>
            <div class="col-xl-3 col-md-6"><div class="card border-0 shadow-sm rounded-0 h-100"><div class="card-body"><div class="text-muted">Doanh thu tháng này</div><h3 class="fw-bold mb-0">@Model.ThisMonthRevenue.ToString("N0") đ</h3><small class="@(Model.RevenueGrowthPercent >= 0 ? "text-success" : "text-danger")">@(Model.RevenueGrowthPercent >= 0 ? "+" : "")@Model.RevenueGrowthPercent% so với tháng trước</small></div></div></div>
            <div class="col-xl-3 col-md-6"><div class="card border-0 shadow-sm rounded-0 h-100"><div class="card-body"><div class="text-muted">Tổng đơn hàng</div><h3 class="fw-bold mb-0">@Model.TotalOrders</h3><small class="text-muted">@Model.DeliveredOrders đã giao</small></div></div></div>
            <div class="col-xl-3 col-md-6"><div class="card border-0 shadow-sm rounded-0 h-100"><div class="card-body"><div class="text-muted">Khách hàng</div><h3 class="fw-bold mb-0">@Model.TotalCustomers</h3><small class="text-muted">@Model.TotalProducts sản phẩm đang bán</small></div></div></div>
        </div>
    </section>

    <section class="mb-4">
        <h5 class="fw-bold mb-3">Trạng thái đơn hàng</h5>
        <div class="row g-3">
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-0 text-center"><div class="card-body"><div class="text-warning fw-semibold">Chờ xử lý</div><h4 class="mb-0">@Model.PendingOrders</h4></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-0 text-center"><div class="card-body"><div class="text-primary fw-semibold">Đang giao</div><h4 class="mb-0">@Model.ShippingOrders</h4></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-0 text-center"><div class="card-body"><div class="text-success fw-semibold">Đã giao</div><h4 class="mb-0">@Model.DeliveredOrders</h4></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm rounded-0 text-center"><div class="card-body"><div class="text-danger fw-semibold">Đã hủy</div><h4 class="mb-0">@Model.CancelledOrders</h4></div></div></div>
        </div>
    </section>

    <section class="mb-4">
        <h5 class="fw-bold mb-3">Biểu đồ doanh thu</h5>
        <div class="row g-4">
            <div class="col-xl-6"><div class="card border-0 shadow-sm rounded-0"><div class="card-header bg-white fw-bold">7 ngày gần nhất</div><div class="card-body"><canvas id="weekChart" height="130"></canvas></div></div></div>
            <div class="col-xl-6"><div class="card border-0 shadow-sm rounded-0"><div class="card-header bg-white fw-bold">Từng ngày trong tháng</div><div class="card-body"><canvas id="monthChart" height="130"></canvas></div></div></div>
            <div class="col-12"><div class="card border-0 shadow-sm rounded-0"><div class="card-header bg-white fw-bold">Doanh thu theo tháng năm @DateTime.Today.Year</div><div class="card-body"><canvas id="yearChart" height="80"></canvas></div></div></div>
        </div>
    </section>

    <section class="mb-4">
        <h5 class="fw-bold mb-3">Thống kê sản phẩm</h5>
        <div class="row g-4">
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-0 h-100">
                    <div class="card-header bg-white fw-bold">Top 5 sản phẩm bán chạy</div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light"><tr><th>Sản phẩm</th><th class="text-center">Đã bán</th><th class="text-end">Doanh thu</th></tr></thead>
                            <tbody>
                                @if (!Model.TopSellingProducts.Any())
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-4">Chưa có dữ liệu.</td></tr>
                                }
                                else
                                {
                                    @foreach (var item in Model.TopSellingProducts)
                                    {
                                        <tr><td class="fw-semibold">@item.ProductName</td><td class="text-center">@item.QuantitySold</td><td class="text-end fw-bold text-danger">@item.Revenue.ToString("N0") đ</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-0 h-100">
                    <div class="card-header bg-white fw-bold">Doanh thu theo danh mục</div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light"><tr><th>Danh mục</th><th class="text-center">Đã bán</th><th class="text-end">Doanh thu</th></tr></thead>
                            <tbody>
                                @if (!Model.CategoryRevenue.Any())
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-4">Chưa có dữ liệu.</td></tr>
                                }
                                else
                                {
                                    @foreach (var item in Model.CategoryRevenue)
                                    {
                                        <tr><td class="fw-semibold">@item.CategoryName</td><td class="text-center">@item.QuantitySold</td><td class="text-end fw-bold text-danger">@item.Revenue.ToString("N0") đ</td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-4">
        <h5 class="fw-bold mb-3">Thanh toán và tồn kho</h5>
        <div class="row g-4">
            <div class="col-xl-5">
                <div class="card border-0 shadow-sm rounded-0 h-100">
                    <div class="card-header bg-white fw-bold">Thống kê phương thức thanh toán</div>
                    <div class="card-body">
                        <canvas id="paymentChart" height="180"></canvas>
                        <div class="mt-3">
                            @foreach (var item in Model.PaymentStatistics)
                            {
                                <div class="d-flex justify-content-between border-bottom py-2"><span>@item.PaymentMethod (@item.OrderCount đơn)</span><strong>@item.Revenue.ToString("N0") đ</strong></div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-7">
                <div class="card border-0 shadow-sm rounded-0 h-100">
                    <div class="card-header bg-white d-flex justify-content-between"><strong>Biến thể sắp hết hàng</strong><span class="badge bg-danger rounded-0">@Model.LowStockCount biến thể</span></div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light"><tr><th>Sản phẩm</th><th class="text-center">Size</th><th class="text-center">Màu</th><th class="text-center">Tồn</th></tr></thead>
                            <tbody>
                                @if (!Model.LowStockItems.Any())
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-4">Không có sản phẩm sắp hết.</td></tr>
                                }
                                else
                                {
                                    @foreach (var item in Model.LowStockItems)
                                    {
                                        <tr><td class="fw-semibold">@item.ProductName</td><td class="text-center">@item.Size</td><td class="text-center">@item.Color</td><td class="text-center"><span class="badge @(item.Quantity == 0 ? "bg-danger" : "bg-warning text-dark")">@item.Quantity</span></td></tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="card border-0 shadow-sm rounded-0">
            <div class="card-header bg-white d-flex justify-content-between align-items-center"><strong>Đơn hàng mới nhất</strong><a href="@Url.Action("Index", "Order", new { area = "Admin" })" class="btn btn-sm btn-outline-primary rounded-0">Xem tất cả</a></div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light"><tr><th>Mã đơn</th><th>Người nhận</th><th>Ngày đặt</th><th class="text-end">Tổng tiền</th><th class="text-center">Trạng thái</th></tr></thead>
                    <tbody>
                        @if (!Model.RecentOrders.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">Chưa có đơn hàng.</td></tr>
                        }
                        else
                        {
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td><a href="@Url.Action("Details", "Order", new { area = "Admin", id = order.Id })" class="fw-bold text-decoration-none">#HS-@order.Id</a></td>
                                    <td>@order.ReceiverName</td>
                                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end fw-bold text-danger">@order.TotalPrice.ToString("N0") đ</td>
                                    <td class="text-center"><span class="badge @order.Status.ToBadgeClass() rounded-pill">@order.Status.ToDisplayName()</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const weekLabels = @Html.Raw(JsonSerializer.Serialize(Model.WeekLabels));
        const weekValues = @Html.Raw(JsonSerializer.Serialize(Model.WeekRevenue));
        const monthLabels = @Html.Raw(JsonSerializer.Serialize(Model.MonthLabels));
        const monthValues = @Html.Raw(JsonSerializer.Serialize(Model.MonthRevenue));
        const yearLabels = @Html.Raw(JsonSerializer.Serialize(Model.YearLabels));
        const yearValues = @Html.Raw(JsonSerializer.Serialize(Model.YearRevenue));
        const paymentLabels = @Html.Raw(JsonSerializer.Serialize(Model.PaymentStatistics.Select(x => x.PaymentMethod)));
        const paymentValues = @Html.Raw(JsonSerializer.Serialize(Model.PaymentStatistics.Select(x => x.Revenue)));

        function revenueChart(id, type, labels, values) {
        new Chart(document.getElementById(id), {
        type,
        data: { labels, datasets: [{ label: 'Doanh thu', data: values, borderWidth: 2, tension: .3 }] },
        options: { responsive: true, scales: { y: { beginAtZero: true, ticks: { callback: value => Number(value).toLocaleString('vi-VN') + ' đ' } } } }
        });
        }

        revenueChart('weekChart', 'line', weekLabels, weekValues);
        revenueChart('monthChart', 'line', monthLabels, monthValues);
        revenueChart('yearChart', 'bar', yearLabels, yearValues);
        new Chart(document.getElementById('paymentChart'), { type: 'doughnut', data: { labels: paymentLabels, datasets: [{ data: paymentValues }] }, options: { responsive: true } });
    </script>
}
