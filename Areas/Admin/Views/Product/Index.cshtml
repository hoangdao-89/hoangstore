@model IEnumerable<hoangstore.Models.Product>

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 style="color: purple">Danh sách sản phẩm</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-primary" style="background-color: purple; border:none">
                <i class="bi bi-plus-circle"></i> Thêm mới sản phẩm
            </a>
        </div>
    </div>

    <table class="table table-bordered table-striped mt-3 text-center align-middle">
        <thead class="table-light">
            <tr>
                <th>Tên sản phẩm</th>
                <th style="width: 100px;">Hình ảnh</th>
                <th>Mô tả</th>
                <th>Giá tiền</th>
                <th>Tổng tồn kho</th>
                <th>Danh mục</th>
                <th style="width: 150px;">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                // TÍNH TOÁN LOGIC TỪ BIẾN THỂ (PRODUCT VARIANTS)
                // 1. Lấy giá thấp nhất trong các size/màu để hiển thị đại diện
                var minPrice = item.ProductVariants != null && item.ProductVariants.Any()
                               ? item.ProductVariants.Min(v => v.Price)
                               : 0;

                // 2. Cộng dồn tất cả số lượng trong kho của các size/màu lại
                var totalQuantity = item.ProductVariants != null && item.ProductVariants.Any()
                                   ? item.ProductVariants.Sum(v => v.Quantity)
                                   : 0;

                <tr>
                    <td class="text-start fw-bold">@item.Product_Name</td>
                    <td>
                        <img src="@item.Image_Url" alt="Product Image" class="img-thumbnail" style="width: 60px; height: 60px; object-fit: cover;" />
                    </td>
                    <td class="text-start text-truncate" style="max-width: 250px;">@item.Product_Description</td>

                    <td class="fw-bold text-danger">
                        @if (minPrice > 0)
                        {
                            <span>Từ @minPrice.ToString("N0") đ</span>
                        }
                        else
                        {
                            <span class="text-muted fs-7">Chưa nhập giá</span>
                        }
                    </td>

                    <td>
                        @if (totalQuantity > 0)
                        {
                            <span class="badge bg-success">@totalQuantity cái</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Hết hàng</span>
                        }
                    </td>

                    <td>@item.Category?.Category_Name</td>
                    <td>
                        <div class="d-flex justify-content-center gap-2">
                            <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary">Sửa</a>
                            <button onclick="DeleteProduct('/Admin/Product/Delete/@item.ProductId', this)" class="btn btn-sm btn-outline-danger">
                                Xóa
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function DeleteProduct(url, button) {
            Swal.fire({
                title: 'Bạn có chắc chắn muốn xóa?',
                text: "Sản phẩm này sẽ được chuyển vào trạng thái xóa mềm!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: 'purple',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: url,
                        type: 'DELETE',
                        success: function (data) {
                           if(data.success){
                               $(button).closest('tr').remove();
                           }
                           else{
                               Swal.fire('Lỗi!','Không thể xóa sản phẩm này', 'error');
                           }
                        },
                        error: function(){
                            Swal.fire('Lỗi', 'Lỗi hệ thống','error');
                        }
                    });
                }
            })
        }
    </script>
}