@model IEnumerable<hoangstore.Models.Product>
@using hoangstore.Models.Enums

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var products = Model?.ToList() ?? new List<hoangstore.Models.Product>();
    var searchTerm = ViewBag.SearchTerm as string ?? string.Empty;
    int? selectedCategory = ViewBag.CategoryId;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalItems = (int)(ViewBag.TotalItems ?? 0);
    var hasFilter = !string.IsNullOrWhiteSpace(searchTerm) || selectedCategory.HasValue;
}

<div class="container-fluid py-4">
    @Html.AntiForgeryToken()

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">Quản lý sản phẩm</h2>
            <p class="text-muted mb-0">Quản lý sản phẩm, hình ảnh và biến thể.</p>
        </div>

        <a asp-area="Admin" asp-controller="Product" asp-action="Create"
           class="btn btn-primary rounded-0 px-4">
            <i class="bi bi-plus-circle me-1"></i>Thêm mới sản phẩm
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successAlert" class="alert alert-success alert-dismissible fade show rounded-0">
            <i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
        </div>
    }

    <div class="card border-0 rounded-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <form asp-area="Admin" asp-controller="Product" asp-action="Index" method="get">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label for="searchTerm" class="form-label fw-semibold">Tên sản phẩm</label>
                        <input type="search" id="searchTerm" name="searchTerm" value="@searchTerm"
                               class="form-control rounded-0" maxlength="100"
                               placeholder="Nhập tên sản phẩm..." />
                    </div>

                    <div class="col-md-4">
                        <label for="categoryId" class="form-label fw-semibold">Danh mục</label>
                        <select id="categoryId" name="categoryId" asp-items="ViewBag.CategoryList"
                                class="form-select rounded-0">
                            <option value="">Tất cả danh mục</option>
                        </select>
                    </div>

                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-dark rounded-0">
                            <i class="bi bi-search me-1"></i>Tìm kiếm
                        </button>

                        @if (hasFilter)
                        {
                            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                               class="btn btn-outline-secondary rounded-0">
                                Xóa lọc
                            </a>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 rounded-0 shadow-sm">
        <div class="card-header bg-white p-4 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0">Danh sách sản phẩm</h5>
            <span class="badge bg-light text-dark border rounded-0">Tổng số: @totalItems</span>
        </div>

        <div class="card-body p-0">
            @if (!products.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-box-seam text-muted" style="font-size:3rem"></i>
                    <h5 class="mt-3">Không tìm thấy sản phẩm</h5>
                    <p class="text-muted mb-0">Không có sản phẩm phù hợp với điều kiện tìm kiếm.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center" style="width:70px">STT</th>
                                <th>Sản phẩm</th>
                                <th>Danh mục</th>
                                <th>Giới tính</th>
                                <th class="text-center">Biến thể</th>
                                <th class="text-center">Tồn kho</th>
                                <th class="text-center">Nổi bật</th>
                                <th class="text-center" style="min-width:300px">Thao tác</th>
                            </tr>
                        </thead>

                        <tbody>
                            @{
                                var index = (currentPage - 1) * 10 + 1;
                            }

                            @foreach (var item in products)
                            {
                                var variants = item.ProductVariants.Where(x => !x.IsDeleted).ToList();
                                var totalStock = variants.Sum(x => x.Quantity);
                                var image = string.IsNullOrWhiteSpace(item.Image_Url)
                                    ? "/images/no-image.png"
                                    : item.Image_Url;

                                <tr>
                                    <td class="text-center">@index</td>

                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@image" alt="@item.Product_Name" class="border"
                                                 style="width:65px;height:65px;object-fit:cover"
                                                 onerror="this.src='/images/no-image.png'" />

                                            <div>
                                                <div class="fw-semibold">@item.Product_Name</div>
                                                <div class="text-muted small">Mã: #@item.ProductId</div>
                                            </div>
                                        </div>
                                    </td>

                                    <td>@item.Category?.Category_Name</td>
                                    <td>@(item.Gender == ProductGender.Male ? "Nam" : item.Gender == ProductGender.Female ? "Nữ" : "Unisex")</td>

                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border rounded-0">
                                            @variants.Count
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        @if (totalStock > 0)
                                        {
                                            <span class="badge bg-success rounded-pill">@totalStock</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger rounded-pill">Hết hàng</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        @if (item.IsFeatured)
                                        {
                                            <i class="bi bi-star-fill text-warning" title="Sản phẩm nổi bật"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-muted" title="Sản phẩm thường"></i>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-area="Admin" asp-controller="Product" asp-action="Variants"
                                               asp-route-id="@item.ProductId"
                                               class="btn btn-sm btn-outline-dark rounded-0">
                                                <i class="bi bi-boxes me-1"></i>Biến thể
                                            </a>

                                            <a asp-area="Admin" asp-controller="Product" asp-action="Edit"
                                               asp-route-id="@item.ProductId"
                                               class="btn btn-sm btn-outline-primary rounded-0">
                                                <i class="bi bi-pencil-square me-1"></i>Sửa
                                            </a>

                                            <button type="button" class="btn btn-sm btn-outline-danger rounded-0"
                                                    onclick="deleteProduct(@item.ProductId, this)">
                                                <i class="bi bi-trash me-1"></i>Xóa
                                            </button>
                                        </div>
                                    </td>
                                </tr>

                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-4" aria-label="Phân trang sản phẩm">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link rounded-0"
                       asp-area="Admin" asp-controller="Product" asp-action="Index"
                       asp-route-page="@(currentPage - 1)"
                       asp-route-searchTerm="@searchTerm"
                       asp-route-categoryId="@selectedCategory">
                        Trước
                    </a>
                </li>

                @for (var pageNumber = 1; pageNumber <= totalPages; pageNumber++)
                {
                    <li class="page-item @(pageNumber == currentPage ? "active" : "")">
                        <a class="page-link rounded-0"
                           asp-area="Admin" asp-controller="Product" asp-action="Index"
                           asp-route-page="@pageNumber"
                           asp-route-searchTerm="@searchTerm"
                           asp-route-categoryId="@selectedCategory">
                            @pageNumber
                        </a>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link rounded-0"
                       asp-area="Admin" asp-controller="Product" asp-action="Index"
                       asp-route-page="@(currentPage + 1)"
                       asp-route-searchTerm="@searchTerm"
                       asp-route-categoryId="@selectedCategory">
                        Sau
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        setTimeout(() => {
        const alertElement = document.getElementById('successAlert');
        if (alertElement) bootstrap.Alert.getOrCreateInstance(alertElement).close();
        }, 3000);

        function deleteProduct(id, button) {
        Swal.fire({
        title: 'Xóa sản phẩm?',
        text: 'Sản phẩm sẽ được ẩn khỏi hệ thống.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Xác nhận xóa',
        cancelButtonText: 'Quay lại',
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d'
        }).then(result => {
        if (!result.isConfirmed) return;

        const token = document.querySelector(
        'input[name="__RequestVerificationToken"]'
        )?.value;

        const oldContent = button.innerHTML;
        button.disabled = true;
        button.innerHTML =
        '<span class="spinner-border spinner-border-sm me-1"></span>Đang xóa';

        $.ajax({
        url: '/Admin/Product/Delete/' + id,
        type: 'DELETE',
        headers: { 'RequestVerificationToken': token },

        success: function (data) {
        if (!data?.success) {
        button.disabled = false;
        button.innerHTML = oldContent;
        Swal.fire(
        'Không thể xóa',
        data?.message || 'Có lỗi xảy ra.',
        'warning'
        );
        return;
        }

        Swal.fire({
        icon: 'success',
        title: 'Thành công',
        text: data.message,
        timer: 1200,
        showConfirmButton: false
        }).then(() => location.reload());
        },

        error: function () {
        button.disabled = false;
        button.innerHTML = oldContent;
        Swal.fire('Lỗi', 'Có lỗi hệ thống xảy ra.', 'error');
        }
        });
        });
        }
    </script>
}