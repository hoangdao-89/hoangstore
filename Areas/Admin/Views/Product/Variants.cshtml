@model IEnumerable<hoangstore.Models.ProductVariant>
@using hoangstore.Models

@{
    ViewData["Title"] = "Biến thể sản phẩm";
    var product = ViewBag.Product as Product;
    var variants = Model?.ToList() ?? new List<ProductVariant>();
}

<div class="container-fluid py-4">
    @Html.AntiForgeryToken()

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">Biến thể sản phẩm</h2>
            <p class="text-muted mb-0">@product?.Product_Name</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
               class="btn btn-outline-secondary rounded-0">
                <i class="bi bi-arrow-left me-1"></i>Danh sách sản phẩm
            </a>

            <a asp-area="Admin" asp-controller="Product" asp-action="CreateVariant"
               asp-route-productId="@product?.ProductId" class="btn btn-primary rounded-0">
                <i class="bi bi-plus-circle me-1"></i>Thêm biến thể
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successAlert" class="alert alert-success alert-dismissible fade show rounded-0">
            <i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 rounded-0 shadow-sm">
        <div class="card-header bg-white p-4 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0">Danh sách biến thể</h5>
            <span class="badge bg-light text-dark border rounded-0">Tổng số: @variants.Count</span>
        </div>

        <div class="card-body p-0">
            @if (!variants.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-boxes text-muted" style="font-size:3rem"></i>
                    <h5 class="mt-3">Chưa có biến thể</h5>
                    <p class="text-muted mb-0">Thêm size, màu sắc, giá và số lượng cho sản phẩm.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center">STT</th>
                                <th>Ảnh</th>
                                <th>Size</th>
                                <th>Màu sắc</th>
                                <th class="text-end">Giá</th>
                                <th class="text-center">Tồn kho</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var index = 1;
                            }

                            @foreach (var item in variants)
                            {
                                var image = string.IsNullOrWhiteSpace(item.Variant_Image_Url)
                                    ? product?.Image_Url
                                    : item.Variant_Image_Url;

                                if (string.IsNullOrWhiteSpace(image)) image = "/images/no-image.png";

                                <tr>
                                    <td class="text-center">@index</td>
                                    <td>
                                        <img src="@image" alt="@item.Color" class="border"
                                             style="width:60px;height:60px;object-fit:cover"
                                             onerror="this.src='/images/no-image.png'" />
                                    </td>
                                    <td><span class="badge bg-dark rounded-0">@item.Size</span></td>
                                    <td>@item.Color</td>
                                    <td class="text-end fw-semibold">@item.Price.ToString("N0") đ</td>
                                    <td class="text-center">
                                        @if (item.Quantity > 0)
                                        {
                                            <span class="badge bg-success rounded-pill">@item.Quantity</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger rounded-pill">Hết hàng</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-area="Admin" asp-controller="Product" asp-action="EditVariant"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-primary rounded-0">
                                                <i class="bi bi-pencil-square me-1"></i>Sửa
                                            </a>

                                            <button type="button" class="btn btn-sm btn-outline-danger rounded-0"
                                                    onclick="deleteVariant(@item.Id, this)">
                                                <i class="bi bi-trash me-1"></i>Xóa
                                            </button>
                                        </div>
                                    </td>
                                </tr>

                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        setTimeout(() => {
        const element = document.getElementById('successAlert');
        if (element) bootstrap.Alert.getOrCreateInstance(element).close();
        }, 3000);

        function deleteVariant(id, button) {
        Swal.fire({
        title: 'Xóa biến thể?',
        text: 'Biến thể sẽ được ẩn khỏi hệ thống.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Xác nhận xóa',
        cancelButtonText: 'Quay lại',
        confirmButtonColor: '#dc3545'
        }).then(result => {
        if (!result.isConfirmed) return;

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const oldContent = button.innerHTML;

        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang xóa';

        $.ajax({
        url: '/Admin/Product/DeleteVariant/' + id,
        type: 'DELETE',
        headers: { 'RequestVerificationToken': token },

        success: function (data) {
        if (!data?.success) {
        button.disabled = false;
        button.innerHTML = oldContent;
        Swal.fire('Không thể xóa', data?.message || 'Có lỗi xảy ra.', 'warning');
        return;
        }

        Swal.fire({
        icon: 'success',
        title: 'Thành công',
        text: data.message,
        timer: 1200,
        showConfirmButton: false
        }).then(() => location.reload());
        },

        error: function () {
        button.disabled = false;
        button.innerHTML = oldContent;
        Swal.fire('Lỗi', 'Có lỗi hệ thống xảy ra.', 'error');
        }
        });
        });
        }
    </script>
}