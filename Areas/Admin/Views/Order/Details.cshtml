@model hoangstore.Models.Order
@using hoangstore.Models.Enums
@using hoangstore.Helpers

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var isVnPay = string.Equals(Model.PaymentMethod, "VNPAY", StringComparison.OrdinalIgnoreCase);
}

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">Chi tiết đơn hàng #HS-@Model.Id</h2>
            <p class="text-muted mb-0">Đặt lúc @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
        </div>

        <a asp-area="Admin" asp-controller="Order" asp-action="Index"
           class="btn btn-outline-secondary rounded-0">
            <i class="bi bi-arrow-left me-1"></i>Quay lại
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successAlert" class="alert alert-success alert-dismissible fade show rounded-0">
            <i class="bi bi-check-circle me-1"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div id="errorAlert" class="alert alert-danger alert-dismissible fade show rounded-0">
            <i class="bi bi-exclamation-circle me-1"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card border-0 rounded-0 shadow-sm h-100">
                <div class="card-header bg-white p-4">
                    <h5 class="fw-bold mb-0">Thông tin người nhận</h5>
                </div>

                <div class="card-body p-4">
                    <div class="mb-3">
                        <div class="text-muted small">Họ và tên</div>
                        <div class="fw-semibold">@Model.ReceiverName</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Số điện thoại</div>
                        <div>@Model.ReceiverPhone</div>
                    </div>

                    <div>
                        <div class="text-muted small">Địa chỉ giao hàng</div>
                        <div>@Model.ShippingAddress</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 rounded-0 shadow-sm h-100">
                <div class="card-header bg-white p-4">
                    <h5 class="fw-bold mb-0">Thông tin đơn hàng</h5>
                </div>

                <div class="card-body p-4">
                    <div class="mb-3">
                        <div class="text-muted small">Tài khoản đặt hàng</div>
                        <div>@(Model.User?.Email ?? "Không xác định")</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Phương thức thanh toán</div>
                        <span class="badge @(isVnPay ? "bg-info text-dark" : "bg-secondary")">
                            @Model.PaymentMethod
                        </span>
                    </div>

                    <div>
                        <div class="text-muted small">Trạng thái</div>
                        <span class="badge @Model.Status.ToBadgeClass() rounded-pill px-3 py-2">
                            @Model.Status.ToDisplayName()
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 rounded-0 shadow-sm mb-4">
        <div class="card-header bg-white p-4">
            <h5 class="fw-bold mb-0">Sản phẩm đã mua</h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Phân loại</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.OrderDetails)
                        {
                            var variant = item.ProductVariant;
                            var image = !string.IsNullOrWhiteSpace(variant?.Variant_Image_Url)
                                ? variant.Variant_Image_Url
                                : variant?.Product?.Image_Url;

                            if (string.IsNullOrWhiteSpace(image)) image = "/images/no-image.png";

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@image" alt="@variant?.Product?.Product_Name" class="border"
                                             style="width:65px;height:65px;object-fit:cover"
                                             onerror="this.src='/images/no-image.png'" />

                                        <div>
                                            <div class="fw-semibold">
                                                @(variant?.Product?.Product_Name ?? "Sản phẩm không còn tồn tại")
                                            </div>
                                            <div class="text-muted small">Mã biến thể: #@item.ProductVariantId</div>
                                        </div>
                                    </div>
                                </td>

                                <td>@variant?.Size / @variant?.Color</td>
                                <td class="text-end">@item.Price.ToString("N0") đ</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end fw-bold text-danger">
                                    @((item.Price * item.Quantity).ToString("N0")) đ
                                </td>
                            </tr>
                        }
                    </tbody>

                    <tfoot class="table-light">
                        <tr>
                            <td colspan="4" class="text-end fw-bold">Tổng cộng:</td>
                            <td class="text-end fw-bold text-danger fs-5">
                                @Model.TotalPrice.ToString("N0") đ
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="card border-0 rounded-0 shadow-sm">
        <div class="card-header bg-white p-4">
            <h5 class="fw-bold mb-0">Xử lý đơn hàng</h5>
        </div>

        <div class="card-body p-4 text-center">
            @if (Model.Status == OrderStatus.Pending && !isVnPay)
            {
                <button type="button" class="btn btn-primary rounded-0 me-2"
                        onclick="confirmStatus(@((int)OrderStatus.Shipping), 'Chuyển đơn sang trạng thái đang giao?')">
                    <i class="bi bi-truck me-1"></i>Xác nhận giao hàng
                </button>

                <button type="button" class="btn btn-outline-danger rounded-0"
                        onclick="confirmStatus(@((int)OrderStatus.Cancelled), 'Hủy đơn hàng này? Tồn kho sẽ được hoàn lại.')">
                    Hủy đơn hàng
                </button>
            }
            else if (Model.Status == OrderStatus.Pending && isVnPay)
            {
                <div class="alert alert-warning rounded-0">
                    Đơn VNPAY chưa thanh toán. Chỉ có thể chờ khách thanh toán hoặc hủy đơn.
                </div>

                <button type="button" class="btn btn-outline-danger rounded-0"
                        onclick="confirmStatus(@((int)OrderStatus.Cancelled), 'Hủy đơn hàng này? Tồn kho sẽ được hoàn lại.')">
                    Hủy đơn hàng
                </button>
            }
            else if (Model.Status == OrderStatus.Processing)
            {
                <button type="button" class="btn btn-primary rounded-0 me-2"
                        onclick="confirmStatus(@((int)OrderStatus.Shipping), 'Xác nhận bắt đầu giao đơn hàng?')">
                    <i class="bi bi-truck me-1"></i>Xác nhận giao hàng
                </button>

                <button type="button" class="btn btn-outline-danger rounded-0"
                        onclick="confirmStatus(@((int)OrderStatus.Cancelled), 'Hủy đơn hàng đã thanh toán? Tồn kho sẽ được hoàn lại.')">
                    Hủy đơn hàng
                </button>
            }
            else if (Model.Status == OrderStatus.Shipping)
            {
                <button type="button" class="btn btn-success rounded-0 me-2"
                        onclick="confirmStatus(@((int)OrderStatus.Delivered), 'Xác nhận khách hàng đã nhận được hàng?')">
                    <i class="bi bi-check-circle me-1"></i>Đã giao thành công
                </button>

                <button type="button" class="btn btn-outline-danger rounded-0"
                        onclick="confirmStatus(@((int)OrderStatus.Cancelled), 'Xác nhận giao thất bại và hủy đơn? Tồn kho sẽ được hoàn lại.')">
                    Giao thất bại
                </button>
            }
            else
            {
                <div class="alert alert-secondary rounded-0 mb-0">
                    Đơn hàng đã đóng luồng xử lý: @Model.Status.ToDisplayName().
                </div>
            }

            <form id="statusForm" asp-area="Admin" asp-controller="Order"
                  asp-action="UpdateStatus" method="post" class="d-none">
                <input type="hidden" name="orderId" value="@Model.Id" />
                <input type="hidden" id="newStatusInput" name="orderStatus" />
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        setTimeout(() => {
        ['successAlert', 'errorAlert'].forEach(id => {
        const element = document.getElementById(id);
        if (element) bootstrap.Alert.getOrCreateInstance(element).close();
        });
        }, 3000);

        function confirmStatus(status, message) {
        Swal.fire({
        title: message,
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Xác nhận',
        cancelButtonText: 'Quay lại',
        confirmButtonColor: status === @((int)OrderStatus.Cancelled) ? '#dc3545' : '#198754',
        cancelButtonColor: '#6c757d'
        }).then(result => {
        if (!result.isConfirmed) return;

        document.getElementById('newStatusInput').value = status;
        document.getElementById('statusForm').submit();
        });
        }
    </script>
}