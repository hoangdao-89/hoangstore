@model hoangstore.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <form asp-area="Admin"
                  asp-controller="Category"
                  asp-action="Create"
                  method="post">

                @Html.AntiForgeryToken()

                <div class="card border-0 rounded-0 shadow-sm">
                    <div class="card-header bg-white p-4">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-plus-circle fs-4 text-primary"></i>

                            <h2 class="fw-bold mb-0">
                                Thêm mới danh mục
                            </h2>
                        </div>
                    </div>

                    <div class="card-body p-4">

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger rounded-0"
                             role="alert">
                        </div>

                        <div class="mb-3">
                            <label asp-for="Category_Name"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="Category_Name"
                                   class="form-control rounded-0"
                                   maxlength="100"
                                   autocomplete="off"
                                   placeholder="Nhập tên danh mục" />

                            <span asp-validation-for="Category_Name"
                                  class="text-danger small">
                            </span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description"
                                   class="form-label fw-semibold">
                            </label>

                            <textarea asp-for="Description"
                                      class="form-control rounded-0"
                                      rows="4"
                                      maxlength="200"
                                      placeholder="Nhập mô tả danh mục">
                            </textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger small">
                            </span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DisplayOrder"
                                   class="form-label fw-semibold">
                            </label>

                            <input asp-for="DisplayOrder"
                                   type="number"
                                   min="1"
                                   max="100"
                                   class="form-control rounded-0"
                                   placeholder="Nhập thứ tự từ 1 đến 100" />

                            <span asp-validation-for="DisplayOrder"
                                  class="text-danger small">
                            </span>

                            <div class="form-text">
                                Danh mục có số nhỏ hơn sẽ được ưu tiên hiển thị trước.
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="IsActive"
                                       class="form-check-input"
                                       type="checkbox" />

                                <label asp-for="IsActive"
                                       class="form-check-label fw-semibold">
                                </label>
                            </div>

                            <span asp-validation-for="IsActive"
                                  class="text-danger small">
                            </span>
                        </div>
                    </div>

                    <div class="card-footer bg-white p-4">
                        <div class="d-flex flex-wrap gap-2">

                            <button type="submit"
                                    class="btn btn-primary rounded-0 px-4">

                                <i class="bi bi-check-circle me-1"></i>
                                Lưu danh mục
                            </button>

                            <a asp-area="Admin"
                               asp-controller="Category"
                               asp-action="Index"
                               class="btn btn-outline-secondary rounded-0 px-4">

                                <i class="bi bi-arrow-left me-1"></i>
                                Quay lại
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}