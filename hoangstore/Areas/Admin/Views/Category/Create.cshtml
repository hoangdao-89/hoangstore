@model hoangstore.Models.Category
<div class="container mt-5 ">
    <form method="post">
        <div class="border p-3 shadow-sm">
            <h2 style="color:purple" class="mt-3">
                Thêm mới danh mục
            </h2>
            <hr />
            <div class="mb-3">
                <label class="form-label">Tên danh mục</label>
                <input asp-for="Category_Name" class="form-control"></input>
                <span asp-validation-for="Category_Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Mô tả</label>
                <input asp-for="Description" class="form-control"></input>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Vị trí</label>
                <input asp-for="DisplayOrder" class="form-control"></input>
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <div class="form-check ">
                   
                    <input type="checkbox" id="forIsActive" asp-for="IsActive" class="form-check-input" />
                    <label for="forIsActive" class="form-check-label">Hoạt động</label>
                </div>
                <span asp-validation-for="IsActive" class="text-danger"></span>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary" style="background-color:purple;border:none;width:150px">Lưu lại</button>
                <a asp-action="Index" class="btn btn-secondary" style="width:150px">Quay lại</a>
            </div>
        </div>
        
        
    </form>
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}