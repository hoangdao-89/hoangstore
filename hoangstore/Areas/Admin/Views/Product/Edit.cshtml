@model hoangstore.Models.Product

<div class="container mt-3">
    <form method="post">
        <input type="hidden" asp-for="ProductId" />
        <div class="border p-3 shadow sm-">
            <h2 style="color:purple">Sửa sản phẩm</h2>
            <hr />
            <div class="mb-3">
                <label class="form-label">Tên sản phẩm</label>
                <input asp-for="Product_Name" class="form-control" />
                <span asp-validation-for="Product_Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Giá</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Mô tả</label>
                <input asp-for="Product_Description" class="form-control" />
                <span asp-validation-for="Product_Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Số lượng</label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Danh mục</label>
                <select asp-for="CategoryId" class="form-select">
                    <option disabled >--Chọn danh mục--</option>
                    @foreach (var item in ViewBag.CategoryList)
                    {
                        <option value="@item.CatId">@item.CatName</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary" style="background-color: purple; border:none; width:150px" ;>Lưu lại</button>
                <a asp-action="Index" class="btn btn-secondary" style="width:150px">Quay lại</a>
            </div>
        </div>
    </form>
</div>