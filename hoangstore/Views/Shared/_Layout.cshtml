<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HoangStore</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
       
    </style>
</head>
<body>

    <header>
        <div class="top-utility-bar">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="top-bar-left">
                    <span>Hotline: 1900 xxxx (8:00-22:00)</span>
                </div>
                <div class="top-bar-right d-flex gap-4">
                    <a href="/Admin" class="text-white text-decoration-none">Quản trị</a>
                    <a href="#" class="text-white text-decoration-none">Đăng nhập / Đăng ký</a>
                </div>
            </div>
        </div>

        <div class="main-header">
            <div class="container d-flex align-items-center justify-content-between">

                <div class="header-logo-container">
                    <a href="/" class="text-decoration-none">
                        <h2 class="serif-font m-0 fw-bold text-dark text-uppercase" style="letter-spacing: 2px;">
                            <i class="bi bi-code-slash text-danger"></i> HoangStore
                        </h2>
                    </a>
                </div>

                <div class="header-utility-icons">
                    <a href="#"><i class="bi bi-search"></i></a>
                    <a href="#" class="position-relative">
                        <i class="bi bi-bag"></i>
                        <span class="cart-count">3</span>
                    </a>
                    <a href="#"><i class="bi bi-person"></i></a>
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="torano-footer mt-auto">
        <div class="container">
            <div class="row row-cols-2 row-cols-md-4 g-5">
                <div class="col">
                    <h6 class="serif-font footer-title">Về HoangStore</h6>
                    <p class="text-muted fs-7">Giới thiệu<br>Hệ thống cửa hàng<br>Tuyển dụng</p>
                </div>
                <div class="col">
                    <h6 class="serif-font footer-title">Hỗ trợ khách hàng</h6>
                    <ul class="footer-links">
                        <li><a href="#">Chính sách đổi trả</a></li>
                        <li><a href="#">Chính sách bảo mật</a></li>
                        <li><a href="#">Phương thức thanh toán</a></li>
                    </ul>
                </div>
                <div class="col">
                    <h6 class="serif-font footer-title">Danh mục sản phẩm</h6>
                    <ul class="footer-links">
                        <li><a href="#">Áo nam</a></li>
                        <li><a href="#">Quần nam</a></li>
                        <li><a href="#">Phụ kiện</a></li>
                    </ul>
                </div>
                <div class="col">
                    <h6 class="serif-font footer-title">Liên hệ</h6>
                    <p class="text-muted fs-7">
                        Email: support@hoangstore.com<br>
                        Address: Hanoi, Vietnam
                    </p>
                </div>
            </div>

            <div class="border-top mt-5 pt-4 text-center">
                <p class="text-muted fs-8">&copy; 2026 - HoangStore. Thiết kế lấy cảm hứng từ Torano. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>