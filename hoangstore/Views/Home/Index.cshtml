@model IEnumerable<hoangstore.Models.Product>

@{
    ViewData["Title"] = "Trang chủ - HoangStore";
}

<div class="container torano-hero-banner position-relative overflow-hidden mb-5">
    <img src="~/images/Banner.png" class="img-fluid w-100" alt="Back In Form Banner" style="object-fit: cover; height: 650px; filter: brightness(90%);">
    <div class="banner-text-overlay position-absolute end-0 top-50 translate-middle-y me-5 pe-5 text-end text-white" style="z-index: 10;">
        <h1 class="serif-font text-uppercase fw-bold text-dark m-0" style="font-size: 100px; letter-spacing: -2px; line-height: 0.9;">Back<br>In Form</h1>
        <p class="serif-font fw-light text-dark fs-5 mt-3 text-uppercase" style="letter-spacing: 2px;">Not just back to work - Back with presence</p>
    </div>
</div>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h3 class="serif-font text-uppercase fw-bold text-dark m-0" style="letter-spacing: 1px;">
            <i class="bi bi-star-fill text-danger me-2"></i>Sản phẩm nổi bật
        </h3>
        <span class="badge bg-light text-secondary border">Tổng số: @Model.Count() sản phẩm</span>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            // TÍNH TOÁN GIÁ THẤP NHẤT TỪ DANH SÁCH BIẾN THỂ ĐỂ HIỂN THỊ
            var minPrice = item.ProductVariants != null && item.ProductVariants.Any()
                           ? item.ProductVariants.Min(v => v.Price)
                           : 0;

            <div class="col torano-product-card">
                <div class="card h-100 shadow-sm border-0 position-relative rounded-0 transition-transform">
                    <img src="@(string.IsNullOrEmpty(item.Image_Url) ? "https://placehold.co/400x400?text=" + item.Product_Name : item.Image_Url)" class="card-img-top p-0 rounded-0" alt="@item.Product_Name" style="object-fit: cover; aspect-ratio: 1/1;">

                    <div class="card-body d-flex flex-column pt-3 px-3">
                        <span class="badge bg-light text-secondary mb-2 align-self-start border fs-9 rounded-0 text-uppercase">
                            @item.Category?.Category_Name
                        </span>

                        <h6 class="card-title fw-bold text-dark text-truncate mb-2 text-uppercase fs-8" title="@item.Product_Name">
                            @item.Product_Name
                        </h6>

                        <p class="card-text text-danger fw-bold fs-6 mb-2">
                            @if (minPrice > 0)
                            {
                                <span>Từ @string.Format("{0:N0}", minPrice) đ</span>
                            }
                            else
                            {
                                <span class="text-muted small fw-normal">Chưa cập nhật giá</span>
                            }
                        </p>

                        @if (item.ProductVariants != null && item.ProductVariants.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label small text-muted mb-1">Chọn kích cỡ & màu sắc:</label>
                                <select class="form-select form-select-sm rounded-0 select-variant" style="font-size: 12px;">
                                    @foreach (var variant in item.ProductVariants)
                                    {
                                        <option value="@variant.Id">
                                            Size: @variant.Size - Màu: @variant.Color (@string.Format("{0:N0}", variant.Price) đ)
                                        </option>
                                    }
                                </select>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <span class="badge bg-warning text-dark rounded-0 w-100 py-2 fs-9">Sản phẩm tạm hết hàng</span>
                            </div>
                        }

                        <div class="mt-auto d-grid gap-2">
                            <button class="btn btn-outline-danger btn-sm fw-bold rounded-0 py-2 fs-8 btn-quick-view" data-id="@item.ProductId" data-action="add-to-cart">
                                <i class="bi bi-cart-plus me-1"></i> Thêm vào giỏ
                            </button>
                            <button class="btn btn-danger btn-sm fw-bold rounded-0 py-2 fs-8 text-uppercase btn-quick-view" data-id="@item.ProductId" data-action="buy-now">
                                Mua ngay
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="quickViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content rounded-0">
            <div id="quickViewModalBody">
            </div>
        </div>
    </div>
</div>

<style>
    .torano-product-card .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .torano-product-card:hover .card {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // KHI BAM VAO NUT THEM OR MUA
        $(document).on('click','.btn-quick-view', function(){
            var productId = $(this).data('id');
            var action = $(this).data('action');
            
            $.ajax({
                url: '/Home/GetQuickView/' + productId,
                type:'GET',
                success: function(res){
                    $('#quickViewModalBody').html(res);
                    $('#quickViewModal').modal('show');
                    $('#currentAction').val(action);
                },
                error: function(){
                    Swal.fire('Lỗi hệ thống', 'Không thể kết nối đến máy chủ lúc này!', 'error');
                }
            });
        });

        var selectedSize = null;
        var selectedColor = null;

        // BAM CHON SIZE TRONG MODAL
        $(document).on('click', '.btn-select-size', function(){
            $('.btn-select-size').removeClass('active-variant');
            $(this).addClass('active-variant');
            selectedSize = $(this).data('size');
            checkMatchingVariant();
        });

        // BAM CHON MAU 
        $(document).on('click', '.btn-select-color', function(){
            $('.btn-select-color').removeClass('active-variant');
            $(this).addClass('active-variant');
            selectedColor = $(this).data('color');
            checkMatchingVariant();
        });

        // TIM KIEM BIEN THE
        function checkMatchingVariant(){
            $('#selectedVariantId').val('');
            $('#variantStockInfo').html('');
            $('#btnConfirmAddToCart').prop('disabled', true);
            
            if(!selectedColor || !selectedSize) return;
            var match = productVariants.find(v => v.size == selectedSize && v.color == selectedColor);

            if(match && match.quantity > 0){
                $('#selectedVariantId').val(match.id);
                $('#quickViewPrice').text(match.price.toLocaleString('vi-VN') + ' đ');
                $('#variantStockInfo').html('<i class="bi bi-check-circle text-success"></i> Còn lại: ' + match.quantity + ' sản phẩm');
                $('#btnConfirmAddToCart').prop('disabled', false);
                if(match.variant_Image_Url) {
                    $('#quickViewImage').attr('src', match.variant_Image_Url);
                }
            }
            else{
                $('#selectedVariantId').val('');
                $('#variantStockInfo').html('<i class="bi bi-x-circle text-danger"></i> Phiên bản này đã hết hàng!');
                $('#btnConfirmAddToCart').prop('disabled', true);
            }
        }

        // BAM CONFIRM ==> LUU VAO DB
        $(document).on('click', '#btnConfirmAddToCart', function(){
            var formData = $('#frmQuickAddToCart').serialize();
            var actionType = $('#currentAction').val();
            
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: formData,
                success: function(res){
                    if(res.success){
                        $('.badge-count').text(res.newCount);
                        $('#quickViewModal').modal('hide');
                        if(actionType == 'buy-now'){
                           window.location.href = '/Cart/Index?buyNowId=' + res.cartItemId;
                        }
                        else{
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công',
                                text: res.message || 'Đã thêm vào giỏ hàng!',
                                timer: 1500,
                                showConfirmButton: false
                            });
                        }
                    }
                    else{
                       if(res.redirectToLogin) {
                            window.location.href = '/Identity/Account/Login?ReturnUrl=' + encodeURIComponent(window.location.pathname);
                       } else {
                            Swal.fire('Thông báo', res.message || 'Có lỗi xảy ra!', 'warning');
                       }
                    }
                }
            });
        });
    </script>
}