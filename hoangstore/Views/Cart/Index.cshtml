@model IEnumerable<hoangstore.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn - HoangStore";
}

<div class="container py-4 pb-5">
    <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
        <h3 class="serif-font text-uppercase fw-bold text-dark m-0 fs-5 fs-md-3">
            <i class="bi bi-bag-check-fill text-danger me-2"></i>Giỏ hàng
        </h3>
        <span class="badge bg-light text-secondary border ms-2 fs-9">@Model.Count() sản phẩm</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 border bg-light shadow-sm">
            <i class="bi bi-cart-x text-muted" style="font-size: 3rem;"></i>
            <p class="fs-6 mt-3 text-secondary">Giỏ hàng của bạn đang trống rỗng.</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-danger rounded-0 px-4 py-2 mt-2 text-uppercase fw-bold fs-8">
                Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12 mb-4 d-none d-md-block">
                <div class="card border-0 shadow-sm rounded-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light text-uppercase fs-9 border-bottom fw-bold text-secondary">
                                <tr>
                                    <th scope="col" class="ps-4 py-3" style="width: 50px;">Chọn</th>
                                    <th scope="col" class="py-3">Sản phẩm</th>
                                    <th scope="col" class="py-3 text-center">Phân loại</th>
                                    <th scope="col" class="py-3 text-center" style="width: 130px;">Đơn giá</th>
                                    <th scope="col" class="py-3 text-center" style="width: 140px;">Số lượng</th>
                                    <th scope="col" class="py-3 text-end" style="width: 140px;">Số tiền</th>
                                    <th scope="col" class="py-3 text-center" style="width: 70px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var imgUrl = !string.IsNullOrEmpty(item.ProductVariant?.Variant_Image_Url)
                                                 ? item.ProductVariant.Variant_Image_Url
                                                 : item.ProductVariant?.Product?.Image_Url;

                                    var itemPrice = item.ProductVariant?.Price ?? 0;
                                    var subTotal = itemPrice * item.Quantity;

                                    <tr class="cart-item-row" data-id="@item.Id" data-price="@itemPrice">
                                        <td class="ps-4 py-3">
                                            <input class="form-check-input rounded-0 cursor-pointer check-cart-item" type="checkbox" value="@item.Id">
                                        </td>
                                        <td class="py-3">
                                            <div class="d-flex align-items-center">
                                                <img src="@(string.IsNullOrEmpty(imgUrl) ? "https://placehold.co/80x80" : imgUrl)"
                                                     class="img-fluid border rounded-0 me-3 shadow-sm"
                                                     style="width: 65px; height: 65px; object-fit: cover;" alt="">
                                                <h6 class="mb-0 fw-bold text-dark text-uppercase fs-8 text-truncate" style="max-width: 250px;" title="@item.ProductVariant?.Product?.Product_Name">
                                                    @item.ProductVariant?.Product?.Product_Name
                                                </h6>
                                            </div>
                                        </td>
                                        <td class="py-3 text-center">
                                            <span class="badge bg-light text-dark border rounded-0 fs-9 py-2 px-2 text-uppercase">
                                                Size: @item.ProductVariant?.Size / Màu: @item.ProductVariant?.Color
                                            </span>
                                        </td>
                                        <td class="py-3 text-center text-secondary fs-8">
                                            @string.Format("{0:N0}", itemPrice) đ
                                        </td>
                                        <td class="py-3 text-center">
                                            <div class="input-group input-group-sm rounded-0 justify-content-center">
                                                <button class="btn btn-outline-secondary btn-update-qty" data-step="-1" type="button">-</button>
                                                <input type="text" class="form-control text-center bg-white txt-quantity" value="@item.Quantity" readonly style="max-width: 40px; font-size: 12px;">
                                                <button class="btn btn-outline-secondary btn-update-qty" data-step="1" type="button">+</button>
                                            </div>
                                        </td>
                                        <td class="py-3 text-end fw-bold text-danger fs-8 pe-3">
                                            <span class="item-subtotal" data-subtotal="@subTotal">@string.Format("{0:N0}", subTotal) đ</span>
                                        </td>
                                        <td class="py-3 text-center">
                                            <button class="btn btn-link link-secondary p-0 btn-delete-single" type="button" data-id="@item.Id" title="Xóa sản phẩm">
                                                <i class="bi bi-trash3 text-muted hover-danger fs-6"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12 d-block d-md-none mb-5">
                @foreach (var item in Model)
                {
                    var imgUrl = !string.IsNullOrEmpty(item.ProductVariant?.Variant_Image_Url) ? item.ProductVariant.Variant_Image_Url : item.ProductVariant?.Product?.Image_Url;
                    var itemPrice = item.ProductVariant?.Price ?? 0;
                    var subTotal = itemPrice * item.Quantity;

                    <div class="card border-0 shadow-sm rounded-0 p-3 mb-3 mobile-cart-card cart-item-row" data-id="@item.Id" data-price="@itemPrice">
                        <div class="d-flex align-items-start gap-2">
                            <div class="pt-2">
                                <input class="form-check-input rounded-0 cursor-pointer check-cart-item" type="checkbox" value="@item.Id">
                            </div>
                            <img src="@(string.IsNullOrEmpty(imgUrl) ? "https://placehold.co/80x80" : imgUrl)" class="border rounded-0" style="width: 75px; height: 75px; object-fit: cover;">

                            <div class="flex-grow-1 min-w-0">
                                <div class="d-flex justify-content-between align-items-start gap-1">
                                    <h6 class="fw-bold text-dark text-uppercase fs-9 text-truncate mb-1" style="max-width: 160px;">
                                        @item.ProductVariant?.Product?.Product_Name
                                    </h6>
                                    <button class="btn p-0 text-muted btn-delete-single" type="button" data-id="@item.Id">
                                        <i class="bi bi-trash3 fs-9"></i>
                                    </button>
                                </div>
                                <div class="text-muted fs-9 text-uppercase mb-1">
                                    Mẫu: Size @item.ProductVariant?.Size - Màu @item.ProductVariant?.Color
                                </div>
                                <div class="text-danger fw-bold fs-8 mb-2">
                                    @string.Format("{0:N0}", itemPrice) đ
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="input-group input-group-sm rounded-0" style="max-width: 90px;">
                                        <button class="btn btn-outline-secondary btn-update-qty py-0 px-2" data-step="-1" type="button">-</button>
                                        <input type="text" class="form-control text-center bg-white txt-quantity py-0 px-1" value="@item.Quantity" readonly style="font-size: 11px;">
                                        <button class="btn btn-outline-secondary btn-update-qty py-0 px-2" data-step="1" type="button">+</button>
                                    </div>
                                    <div class="fw-bold text-danger fs-8">
                                        <span class="item-subtotal" data-subtotal="@subTotal">@string.Format("{0:N0}", subTotal) đ</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-12 fixed-bottom bg-white border-top shadow-lg py-2 px-3 checkout-sticky-bar">
                <div class="container p-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                    <div class="d-flex align-items-center justify-content-between justify-content-md-start gap-3 border-bottom border-md-0 pb-2 pb-md-0 fs-8">
                        <div class="form-check m-0 d-flex align-items-center gap-2">
                            <input class="form-check-input rounded-0 cursor-pointer" type="checkbox" id="check-all-cart">
                            <label class="form-check-label text-dark cursor-pointer fw-bold fw-md-normal" for="check-all-cart" id="lbl-select-all-text">
                                Chọn tất cả (@Model.Count())
                            </label>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-link link-secondary p-0 text-decoration-none fs-9" id="btn-delete-selected" type="button">
                                <i class="bi bi-trash3 me-1"></i>Xóa mục chọn
                            </button>
                        </div>
                    </div>

                    <div class="d-flex align-items-center justify-content-between justify-content-md-end gap-3 gap-md-4">
                        <div class="text-end">
                            <span class="fs-9 text-muted d-none d-md-inline">Tổng thanh toán (<span id="selected-count">0</span> sản phẩm):</span>
                            <span class="fs-9 text-muted d-inline d-md-none">Tổng cộng (<span id="selected-count-mb">0</span>):</span>
                            <div class="fw-bold text-danger fs-5 fs-md-4" id="cart-final-price">0 đ</div>
                        </div>
                        <button type="button" id="btn-proceed-checkout" class="btn btn-danger rounded-0 fw-bold text-uppercase px-4 px-md-5 py-2 py-md-3 fs-8 fs-md-7 shadow-sm" disabled>
                            Mua hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    .fs-9 {
        font-size: 11px !important;
    }

    .fs-8 {
        font-size: 13px !important;
    }

    .hover-danger:hover {
        color: #dc3545 !important;
        transition: color 0.2s;
    }

   
    .cart-item-row-selected {
        background-color: #fffafb !important;
        border: 1px solid #ffccd3 !important;
    }


    .checkout-sticky-bar {
        z-index: 1030;
        box-shadow: 0 -5px 15px rgba(0,0,0,0.08) !important;
    }

   
    body {
        padding-bottom: 60px;
    }

    @@media (max-width: 767.98px) {
        body {
            padding-bottom: 110px;
        }
    }
</style>
@section Scripts{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function(){
            // Ham tinh tong tien gio hang 
            function calculateCartTotal(){
                var total = 0;
                var count = 0;
                
                // Duyet cac o checked dang hien thi thuc te
                $('.check-cart-item:checked:visible').each(function(){
                    var row = $(this).closest('.cart-item-row');
                    var subTotal = parseFloat(row.find('.item-subtotal').data('subtotal')) || 0;
                    total += subTotal;
                    count++;
                });
                
                // Cap nhat gia tri len thanh cong cu thanh sticky bar
                $('#cart-final-price').text(total.toLocaleString('vi-VN') + ' đ');
                $('#selected-count').text(count);
                $('#selected-count-mb').text(count);
                
                // Mo hoac khoa nut mua hang dua vao so luong san pham duoc tich
                if(count > 0){
                    $('#btn-proceed-checkout').prop('disabled', false);
                }
                else {
                    $('#btn-proceed-checkout').prop('disabled', true);
                }
            }

            // Bam nut chon tat ca
            $(document).on('change', '#check-all-cart', function(){
                var isChecked = $(this).is(':checked');
                $('.check-cart-item').prop('checked', isChecked);
                if(isChecked) {
                    $('.cart-item-row').addClass('cart-item-row-selected');
                } else {
                    $('.cart-item-row').removeClass('cart-item-row-selected');
                }
                calculateCartTotal();
            });

            // Chon tung o don le
            $(document).on('change', '.check-cart-item', function () {
                var row = $(this).closest('.cart-item-row');
                var cartItemId = $(this).val();

                $(`.check-cart-item[value="${cartItemId}"]`).prop('checked', $(this).is(':checked'));

                if ($(this).is(':checked')) {
                    $(`.cart-item-row[data-id="${cartItemId}"]`).addClass('cart-item-row-selected');
                } else {
                    $(`.cart-item-row[data-id="${cartItemId}"]`).removeClass('cart-item-row-selected');
                }

                // Check xem da chon tat ca cac o chua de tu dong tich o chon tat ca
                var allChecked = $('.check-cart-item:checked').length === $('.check-cart-item').length;
                $('#check-all-cart').prop('checked', allChecked && $('.check-cart-item').length > 0);

                calculateCartTotal();
            });

            // Xu ly so luong khi bam nut cong + hoac tru -
            $(document).on('click', '.btn-update-qty', function(){
                var button = $(this);
                var row = button.closest('.cart-item-row');
                var cartItemId = row.data('id');
                var step = parseInt(button.data('step'));
                
                $.ajax({
                    url: '/Cart/UpdateQuantity',
                    type: 'POST',
                    data: { cartItemId: cartItemId, step: step },
                    success: function(res){
                        if(res.success){
                            $(`.cart-item-row[data-id="${cartItemId}"]`).find('.txt-quantity').val(res.newQty);
                            var subTotalSpan = $(`.cart-item-row[data-id="${cartItemId}"]`).find('.item-subtotal');
                            subTotalSpan.data('subtotal', res.newSubTotal);
                            subTotalSpan.text(res.newSubTotal.toLocaleString('vi-VN') + ' đ');
                            calculateCartTotal();
                        }
                        else{
                            Swal.fire({
                                icon: 'error',
                                title: 'That bai',
                                text: res.message,
                                timer: 1500,
                                showConfirmButton: false
                            });
                        }
                    }
                });
            });

            // Xu ly xoa don le
            $(document).on('click', '.btn-delete-single', function () {
                var cartItemId = $(this).data('id');

                Swal.fire({
                    title: 'Xac nhan xoa?',
                    text: "San pham se bi xoa khoi gio hang cua ban!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Xoa ngay',
                    cancelButtonText: 'Huy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Cart/DeleteItem',
                            type: 'POST',
                            data: { cartItemId: cartItemId },
                            success: function (res) {
                                if (res.success) {
                                    $(`.cart-item-row[data-id="${cartItemId}"]`).fadeOut(300, function () {
                                        $(this).remove();
                                        calculateCartTotal();
                                        if ($('.cart-item-row').length === 0) {
                                            window.location.reload();
                                        }
                                    });
                                }
                            }
                        });
                    }
                });
            });

            // Xu ly xoa hang loat muc da chon
            $(document).on('click', '#btn-delete-selected', function () {
                var selectedIds = [];
                $('.check-cart-item:checked:visible').each(function () {
                    selectedIds.push(parseInt($(this).val()));
                });

                if (selectedIds.length === 0) {
                    Swal.fire({ icon: 'info', title: 'Thong bao', text: 'Vui long chon it nhat mot san pham de xoa!' });
                    return;
                }

                Swal.fire({
                    title: 'Xoa cac muc da chon?',
                    text: `Ban co chac muon xoa ${selectedIds.length} san pham khoi gio hang?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Xoa het',
                    cancelButtonText: 'Huy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Cart/DeleteSelectedItems',
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify(selectedIds),
                            success: function (res) {
                                if (res.success) {
                                    selectedIds.forEach(id => {
                                        $(`.cart-item-row[data-id="${id}"]`).remove();
                                    });
                                    $('#check-all-cart').prop('checked', false);
                                    calculateCartTotal();
                                    if ($('.cart-item-row').length === 0) {
                                        window.location.reload();
                                    }
                                }
                            }
                        });
                    }
                });
            });

            // TU DONG TICH CHON SAN PHAM KHI BAM MUA NGAY TU TRANG CHU 
            var urlParams = new URLSearchParams(window.location.search);
            var buyNowId = urlParams.get('buyNowId');

            if (buyNowId) {
                // Tu dong tich checkbox phien ban PC va Mobile co ID trung khop
                $(`.check-cart-item[value="${buyNowId}"]`).prop('checked', true);
                $(`.cart-item-row[data-id="${buyNowId}"]`).addClass('cart-item-row-selected');
                
                // Cap nhat lai trang thai o check-all
                var allChecked = $('.check-cart-item:checked').length === $('.check-cart-item').length;
                $('#check-all-cart').prop('checked', allChecked && $('.check-cart-item').length > 0);

                // Tinh lai tong tien de mo khoa nut mua hang
                calculateCartTotal();
            }

            //  XU LY CHUYEN HUONG SANG TRANG CHECKOUT KHI BAM NUT MUA HANG ---
            $(document).on('click', '#btn-proceed-checkout', function() {
                var selectedIds = [];
                // Gom toan bo ID dang duoc checked thuc te tren man hinh
                $('.check-cart-item:checked:visible').each(function() {
                    selectedIds.push($(this).val());
                });

                if (selectedIds.length === 0) {
                    Swal.fire({ icon: 'warning', title: 'Thong bao', text: 'Vui long chon it nhat mot san pham de tien hanh dat hang!' });
                    return;
                }

                // Chuyen mang ID thanh chuoi cach nhau bang dau phay gui sang trang Checkout
                var itemIdsString = selectedIds.join(',');
                window.location.href = '/Order/Checkout?itemIds=' + itemIdsString;
            });
        });
    </script>
}