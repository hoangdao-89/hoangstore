@model hoangstore.Models.Product

@{
    const string fallbackImage = "https://placehold.co/600x700?text=No+Image";

    var productImage = string.IsNullOrWhiteSpace(Model.Image_Url)
        ? fallbackImage
        : Model.Image_Url;

    var activeVariants = Model.ProductVariants?
        .Where(variant => !variant.IsDeleted)
        .OrderBy(variant => variant.Size)
        .ThenBy(variant => variant.Color)
        .ToList()
        ?? new List<hoangstore.Models.ProductVariant>();

    var sellableVariants = activeVariants
        .Where(variant => variant.Quantity > 0)
        .ToList();

    var availableSizes = activeVariants
        .Where(variant => !string.IsNullOrWhiteSpace(variant.Size))
        .Select(variant => variant.Size)
        .Distinct()
        .OrderBy(size => size)
        .ToList();

    var availableColors = activeVariants
        .Where(variant => !string.IsNullOrWhiteSpace(variant.Color))
        .Select(variant => variant.Color)
        .Distinct()
        .OrderBy(color => color)
        .ToList();

    var minPrice = sellableVariants.Any()
        ? sellableVariants.Min(variant => variant.FinalPrice)
        : 0;

    var minOriginalPrice = sellableVariants.Any()
        ? sellableVariants.Min(variant => variant.Price)
        : 0;

    var hasStock = sellableVariants.Any();
}

<div id="quickViewRoot"
     data-default-image="@productImage"
     data-fallback-image="@fallbackImage"
     data-min-price="@minPrice"
     data-has-stock="@hasStock.ToString().ToLowerInvariant()">

    <div class="modal-header border-0 pb-0">
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
    </div>

    <div class="modal-body pt-0">
        <div class="row">
            <div class="col-md-5 mb-3 mb-md-0">
                <img src="@productImage"
                     id="quickViewImage"
                     class="img-fluid w-100 object-fit-cover shadow-sm"
                     style="height: 400px; border: 1px solid #eee;"
                     alt="@Model.Product_Name"
                     onerror="this.onerror=null;this.src='@fallbackImage';" />
            </div>

            <div class="col-md-7 d-flex flex-column justify-content-between">
                <div>
                    <span class="text-muted text-uppercase small tracking-wider">
                        Hoàng Store / @(Model.Category?.Category_Name ?? "Local Brand")
                    </span>

                    <h3 class="fw-bold text-uppercase mt-1 mb-2" style="letter-spacing: -0.5px;">
                        @Model.Product_Name
                    </h3>

                    <h4 class="text-danger fw-bold mb-3" id="quickViewPrice">
                        @if (hasStock && minPrice > 0)
                        {
                            <span>
                                Từ @(minPrice < minOriginalPrice
                                                                    ? $"{minOriginalPrice:N0} đ → {minPrice:N0} đ"
                                                                    : $"{minPrice:N0} đ")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted fs-6 fw-normal">
                                Sản phẩm hiện đã hết hàng
                            </span>
                        }
                    </h4>

                    <hr class="my-3" style="border-top: 1px dashed #ddd;" />

                    <p class="text-muted small mb-4" style="line-height: 1.6;">
                        @if (!string.IsNullOrWhiteSpace(Model.Product_Description))
                        {
                            @Model.Product_Description
                        }
                        else
                        {
                            <span>Sản phẩm chưa có mô tả chi tiết.</span>
                        }
                    </p>

                    @if (!activeVariants.Any())
                    {
                        <div class="alert alert-warning rounded-0 mb-4">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Sản phẩm chưa có phiên bản để lựa chọn.
                        </div>
                    }
                    else if (!hasStock)
                    {
                        <div class="alert alert-warning rounded-0 mb-4">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Tất cả phiên bản của sản phẩm hiện đã hết hàng.
                        </div>
                    }

                    <form id="frmQuickAddToCart">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="ProductId" value="@Model.ProductId" />
                        <input type="hidden" id="selectedVariantId" name="variantId" value="" />
                        <input type="hidden" id="currentAction" value="" />

                        <div class="mb-3">
                            <label class="fw-bold small d-block mb-2 text-uppercase text-secondary"
                                   style="font-size: 11px;">
                                Kích cỡ:
                            </label>

                            <div class="d-flex flex-wrap gap-2">
                                @if (availableSizes.Any())
                                {
                                    @foreach (var size in availableSizes)
                                    {
                                        var sizeHasStock = activeVariants.Any(variant =>
                                            variant.Size == size && variant.Quantity > 0);

                                        <button type="button"
                                                class="btn btn-outline-dark rounded-0 px-3 py-1 btn-select-size @(!sizeHasStock ? "variant-disabled" : "")"
                                                data-size="@size"
                                                data-has-stock="@sizeHasStock.ToString().ToLowerInvariant()"
                                                style="font-weight: 600; font-size: 13px;">
                                            @size
                                        </button>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">Chưa có kích cỡ.</span>
                                }
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold small d-block mb-2 text-uppercase text-secondary"
                                   style="font-size: 11px;">
                                Màu sắc:
                            </label>

                            <div class="d-flex flex-wrap gap-2">
                                @if (availableColors.Any())
                                {
                                    @foreach (var color in availableColors)
                                    {
                                        var colorHasStock = activeVariants.Any(variant =>
                                            variant.Color == color && variant.Quantity > 0);

                                        <button type="button"
                                                class="btn btn-outline-dark rounded-0 px-3 py-1 btn-select-color @(!colorHasStock ? "variant-disabled" : "")"
                                                data-color="@color"
                                                data-has-stock="@colorHasStock.ToString().ToLowerInvariant()"
                                                style="font-weight: 600; font-size: 13px;">
                                            @color
                                        </button>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">Chưa có màu sắc.</span>
                                }
                            </div>
                        </div>

                        <div class="mb-4 d-flex align-items-center gap-3">
                            <label class="fw-bold small m-0 text-uppercase text-secondary"
                                   style="font-size: 11px;">
                                Số lượng:
                            </label>

                            <div class="input-group input-group-sm" style="width: 110px;">
                                <input type="number"
                                       id="quickViewQuantity"
                                       name="quantity"
                                       class="form-control rounded-0 text-center fw-bold"
                                       value="1"
                                       min="1"
                                       max="@(hasStock ? 100 : 1)"
                                       disabled="@(!hasStock)" />
                            </div>

                            <span class="text-muted small fw-medium"
                                  id="variantStockInfo"
                                  style="font-size: 12px;">
                                @if (hasStock)
                                {
                                    <i class="bi bi-info-circle me-1"></i>
                                    <span>Vui lòng chọn size và màu</span>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle text-danger me-1"></i>
                                    <span>Sản phẩm đã hết hàng</span>
                                }
                            </span>
                        </div>
                    </form>
                </div>

                <div class="d-grid mt-3">
                    <button type="button"
                            id="btnConfirmAddToCart"
                            class="btn btn-dark rounded-0 py-2 fw-bold text-uppercase border-dark"
                            style="letter-spacing: 1px; font-size: 14px;"
                            disabled>

                        <span id="confirmButtonText">
                            <i class="bi bi-check-circle-fill me-2"></i>

                            @if (hasStock)
                            {
                                <span>Xác nhận lựa chọn</span>
                            }
                            else
                            {
                                <span>Sản phẩm đã hết hàng</span>
                            }
                        </span>

                        <span id="confirmButtonLoading" class="d-none">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            Đang xử lý...
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .active-variant {
        background-color: #212529 !important;
        color: white !important;
        border-color: #212529 !important;
    }

    .variant-disabled {
        opacity: 0.45;
        text-decoration: line-through;
    }
</style>

<script>
    window.productVariants = @Html.Raw(
                Json.Serialize(
                        activeVariants.Select(variant => new
                        {
                                id = variant.Id,
                                size = variant.Size,
                                color = variant.Color,
                                quantity = variant.Quantity,
                                price = variant.FinalPrice,
                                originalPrice = variant.Price,
                                discountPercent = variant.DiscountPercent,
                                variantImageUrl = variant.Variant_Image_Url
                        })
                )
        );
</script>
