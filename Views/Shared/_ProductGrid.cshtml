@model IEnumerable<hoangstore.Models.Product>

@{
    const string fallbackImage = "https://placehold.co/400x400?text=No+Image";
    var products = Model?.ToList() ?? new List<hoangstore.Models.Product>();
}

@if (!products.Any())
{
    <div class="text-center py-5 border bg-light shadow-sm">
        <i class="bi bi-box-seam text-muted display-5"></i>
        <h5 class="fw-bold text-dark mt-3">Chưa có sản phẩm</h5>
    </div>
}
else
{
    <div class="row row-cols-2 row-cols-lg-4 g-2 g-md-4">
        @foreach (var item in products)
        {
            var activeVariants = item.ProductVariants?
                .Where(v => !v.IsDeleted)
                .OrderBy(v => v.Size)
                .ThenBy(v => v.Color)
                .ToList() ?? new List<hoangstore.Models.ProductVariant>();

            var sellableVariants = activeVariants.Where(v => v.Quantity > 0).ToList();
            var hasStock = sellableVariants.Any();
            var minPrice = hasStock ? sellableVariants.Min(v => v.FinalPrice) : 0;
            var minOriginalPrice = hasStock ? sellableVariants.Min(v => v.Price) : 0;
            var image = string.IsNullOrWhiteSpace(item.Image_Url) ? fallbackImage : item.Image_Url;
            var hasSale = activeVariants.Any(v => v.DiscountPercent > 0);

            <div class="col torano-product-card">
                <div class="card h-100 shadow-sm border-0 position-relative rounded-0">
                    @if (hasSale)
                    {
                        <span class="product-badge badge bg-danger rounded-0">SALE</span>
                    }

                    @if (!hasStock)
                    {
                        <span class="stock-badge badge bg-dark rounded-0">Hết hàng</span>
                    }

                    <img src="@image" class="card-img-top rounded-0 product-card-image"
                         alt="@item.Product_Name"
                         onerror="this.onerror=null;this.src='@fallbackImage';" />

                    <div class="card-body d-flex flex-column p-3">
                        <span class="badge bg-light text-secondary border rounded-0 text-uppercase align-self-start category-badge">
                            @(item.Category?.Category_Name ?? "Chưa phân loại")
                        </span>

                        <h6 class="card-title fw-bold text-dark text-uppercase mt-2 mb-2 product-name"
                            title="@item.Product_Name">
                            @item.Product_Name
                        </h6>

                        <div class="fw-bold mb-2 product-price">
                            @if (hasStock && minPrice > 0)
                            {
                                @if (minPrice < minOriginalPrice)
                                {
                                    <span class="text-muted text-decoration-line-through small me-1">
                                        @minOriginalPrice.ToString("N0") đ
                                    </span>
                                }
                                <span class="text-danger">Từ @minPrice.ToString("N0") đ</span>
                            }
                            else
                            {
                                <span class="text-muted small fw-normal">Sản phẩm hiện đã hết hàng</span>
                            }
                        </div>

                        <div class="text-muted small mb-3 product-note">
                            @if (!activeVariants.Any())
                            {
                                <span>Sản phẩm chưa có phiên bản</span>
                            }
                            else if (!hasStock)
                            {
                                <span>Tất cả phiên bản đã hết hàng</span>
                            }
                            else
                            {
                                <span><i class="bi bi-palette me-1"></i>Chọn size và màu khi mua</span>
                            }
                        </div>

                        <div class="mt-auto d-grid gap-2">
                            <button type="button"
                                    class="btn btn-outline-danger btn-sm fw-bold rounded-0 product-button btn-quick-view"
                                    data-id="@item.ProductId" data-action="add-to-cart" disabled="@(!hasStock)">
                                <i class="bi bi-cart-plus me-1"></i>@(hasStock ? "Thêm vào giỏ" : "Đã hết hàng")
                            </button>

                            <button type="button"
                                    class="btn btn-danger btn-sm fw-bold rounded-0 text-uppercase product-button btn-quick-view"
                                    data-id="@item.ProductId" data-action="buy-now" disabled="@(!hasStock)">
                                @(hasStock ? "Mua ngay" : "Đã hết hàng")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
