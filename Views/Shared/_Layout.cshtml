<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - HoangStore</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="preconnect"
          href="https://fonts.googleapis.com" />

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin />

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />
</head>

<body>
    <header>
        <div class="top-utility-bar">
            <div class="container-wide d-flex
                        justify-content-between
                        align-items-center">

                <div class="top-bar-left">
                    Hotline: 1900 2005 (8:00-22:00)
                </div>

                <div class="top-bar-right d-flex gap-3">
                    <div class="auth-features">

                        @if (User.Identity != null &&
                             User.Identity.IsAuthenticated)
                        {
                            <a asp-area="Identity"
                               asp-page="/Account/Manage/Index"
                               class="text-white text-decoration-none">

                                Hi,
                                @(User.FindFirst("FirstName")?.Value
                                  ?? User.Identity.Name)
                            </a>

                            <span class="text-white mx-1">
                                ||
                            </span>

                            <form id="logoutForm"
                                  class="d-inline"
                                  asp-area="Identity"
                                  asp-page="/Account/Logout"
                                  asp-route-returnUrl="@Url.Action(
                                      "Index",
                                      "Home",
                                      new { area = "" })"
                                  method="post">

                                <a href="javascript:void(0)"
                                   onclick="document.getElementById('logoutForm').submit()"
                                   class="text-white text-decoration-none">

                                    Đăng xuất
                                </a>
                            </form>
                        }
                        else
                        {
                            <a asp-area="Identity"
                               asp-page="/Account/Login"
                               class="text-white text-decoration-none">

                                Đăng nhập
                            </a>

                            <span class="text-white mx-1">
                                |
                            </span>

                            <a asp-area="Identity"
                               asp-page="/Account/Register"
                               class="text-white text-decoration-none">

                                Đăng ký
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="main-header bg-white sticky-top shadow-sm">
            <div class="container-wide d-flex
                        justify-content-between
                        align-items-center">

                <!-- Logo -->
                <div class="header-logo">
                    <a asp-area=""
                       asp-controller="Home"
                       asp-action="Index">

                        <img src="~/images/Logo_HoangStore.png"
                             alt="HoangStore"
                             style="max-height: 100px;
                                    width: auto;
                                    object-fit: contain;" />
                    </a>
                </div>

                <!-- Menu -->
                <div class="header-menu d-none d-lg-block">
                    <ul class="nav justify-content-center">

                        <li class="nav-item">
                            <a class="nav-link active"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">

                                Trang chủ
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               id="navDropdownNam"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">

                                Nam
                            </a>

                            <ul class="dropdown-menu
                                       dropdown-menu-nam
                                       rounded-0 m-0 shadow-lg"
                                aria-labelledby="navDropdownNam">

                                <li>
                                    <a class="dropdown-item
                                              dropdown-item-nam"
                                       href="#">

                                        Áo nam
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item
                                              dropdown-item-nam"
                                       href="#">

                                        Quần nam
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item
                                              dropdown-item-nam"
                                       href="#">

                                        Phụ kiện
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               id="navDropdownNu"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">

                                Nữ
                            </a>

                            <ul class="dropdown-menu
                                       dropdown-menu-nu
                                       rounded-0 m-0 shadow-lg"
                                aria-labelledby="navDropdownNu">

                                <li>
                                    <a class="dropdown-item
                                              dropdown-item-nu"
                                       href="#">

                                        Áo nữ
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item
                                              dropdown-item-nu"
                                       href="#">

                                        Quần nữ
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item
                                              dropdown-item-nu"
                                       href="#">

                                        Váy
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item
                                              dropdown-item-nu"
                                       href="#">

                                        Phụ kiện
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="#">

                                Mới
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               href="#">

                                Nổi bật
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-danger"
                               href="#">

                                Sale
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Khu vực bên phải -->
                <div class="header-right d-flex
                            align-items-center gap-3">

                    <!-- Tìm kiếm -->
                    <form asp-area=""
                          asp-controller="Home"
                          asp-action="Index"
                          asp-fragment="product-list"
                          method="get"
                          class="d-flex position-relative
                                 search-box m-0">

                        <input class="form-control
                                      form-control-sm
                                      border-secondary-subtle
                                      bg-light"
                               type="search"
                               id="searchTerm"
                               name="searchTerm"
                               value="@Context.Request.Query["searchTerm"]"
                               placeholder="Tìm sản phẩm..."
                               aria-label="Tìm sản phẩm"
                               maxlength="100"
                               autocomplete="off" />

                        <button class="btn btn-sm
                                       position-absolute
                                       end-0 top-50
                                       translate-middle-y
                                       border-0
                                       bg-transparent
                                       pe-3"
                                type="submit"
                                aria-label="Tìm kiếm">

                            <i class="bi bi-search text-muted"></i>
                        </button>
                    </form>

                    <!-- Đơn hàng -->
                    <a asp-area=""
                       asp-controller="Order"
                       asp-action="Index"
                       title="Đơn hàng của tôi"
                       aria-label="Đơn hàng của tôi"
                       class="position-relative
                              header-action-link">

                        <i class="bi bi-box-seam"></i>
                    </a>

                    <!-- Giỏ hàng -->
                    <a asp-area=""
                       asp-controller="Cart"
                       asp-action="Index"
                       title="Giỏ hàng"
                       aria-label="Giỏ hàng"
                       class="position-relative
                              header-action-link">

                        <i class="bi bi-bag"></i>

                        @await Component.InvokeAsync("CartCount")
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync(
        "Scripts",
        required: false)
</body>
</html>