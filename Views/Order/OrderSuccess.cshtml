@{
    ViewData["Title"] = "Đặt hàng thành công - HoangStore";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6 py-5 border bg-white shadow-sm px-4">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4.5rem;"></i>
            </div>

            <h2 class="serif-font text-uppercase fw-bold text-dark mb-2">Đặt hàng thành công!</h2>
            <p class="text-secondary mb-4 fs-6">Cảm ơn bạn đã tin tưởng và lựa chọn mua sắm tại HoangStore.</p>

            <div class="bg-light p-3 border mb-4 rounded-0">
                <span class="text-muted d-block small text-uppercase tracking-wider">Mã đơn hàng của bạn</span>
                <span class="fw-bold text-danger fs-4">#HS-@ViewBag.OrderId</span>
            </div>

            <p class="text-muted small mb-5 px-md-3" style="line-height: 1.6;">
                Nhân viên của HoangStore sẽ sớm liên hệ với bạn qua số điện thoại giao hàng để xác nhận thông tin và tiến hành đóng gói chuyển phát.
            </p>

            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                <a href="/" class="btn btn-dark rounded-0 px-4 py-2 text-uppercase fw-bold fs-8">
                    Tiếp tục mua sắm
                </a>
                <a href="#" class="btn btn-outline-secondary rounded-0 px-4 py-2 text-uppercase fw-bold fs-8">
                    Lịch sử đơn hàng
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-8 {
        font-size: 13px !important;
    }
</style>