@model IEnumerable<hoangstore.Models.Product>

@{
    ViewData["Title"] = "Trang chủ - HoangStore";
}

<div class="container torano-hero-banner position-relative overflow-hidden mb-5">
    <img src="~/images/Banner.png" class="img-fluid w-100" alt="Back In Form Banner" style="object-fit: cover; height: 650px; filter: brightness(90%);">
    <div class="banner-text-overlay position-absolute end-0 top-50 translate-middle-y me-5 pe-5 text-end text-white" style="z-index: 10;">
        <h1 class="serif-font text-uppercase fw-bold text-dark m-0" style="font-size: 100px; letter-spacing: -2px; line-height: 0.9;">Back<br>In Form</h1>
        <p class="serif-font fw-light text-dark fs-5 mt-3 text-uppercase" style="letter-spacing: 2px;">Not just back to work - Back with presence</p>
    </div>
</div>

<div class="container pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h3 class="serif-font text-uppercase fw-bold text-dark m-0" style="letter-spacing: 1px;">
            <i class="bi bi-star-fill text-danger me-2"></i>Sản phẩm nổi bật
        </h3>
        <span class="badge bg-light text-secondary border">Tổng số: @Model.Count() sản phẩm</span>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            // TÍNH TOÁN GIÁ THẤP NHẤT TỪ DANH SÁCH BIẾN THỂ ĐỂ HIỂN THỊ
            var minPrice = item.ProductVariants != null && item.ProductVariants.Any()
                           ? item.ProductVariants.Min(v => v.Price)
                           : 0;

            <div class="col torano-product-card">
                <div class="card h-100 shadow-sm border-0 position-relative rounded-0 transition-transform">
                    <img src="@(string.IsNullOrEmpty(item.Image_Url) ? "https://placehold.co/400x400?text=" + item.Product_Name : item.Image_Url)" class="card-img-top p-0 rounded-0" alt="@item.Product_Name" style="object-fit: cover; aspect-ratio: 1/1;">

                    <div class="card-body d-flex flex-column pt-3 px-3">
                        <span class="badge bg-light text-secondary mb-2 align-self-start border fs-9 rounded-0 text-uppercase">
                            @item.Category?.Category_Name
                        </span>

                        <h6 class="card-title fw-bold text-dark text-truncate mb-2 text-uppercase fs-8" title="@item.Product_Name">
                            @item.Product_Name
                        </h6>

                        <p class="card-text text-danger fw-bold fs-6 mb-2">
                            @if (minPrice > 0)
                            {
                                <span>Từ @string.Format("{0:N0}", minPrice) đ</span>
                            }
                            else
                            {
                                <span class="text-muted small fw-normal">Chưa cập nhật giá</span>
                            }
                        </p>

                        @if (item.ProductVariants != null && item.ProductVariants.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label small text-muted mb-1">Chọn kích cỡ & màu sắc:</label>
                                <select class="form-select form-select-sm rounded-0 select-variant" style="font-size: 12px;">
                                    @foreach (var variant in item.ProductVariants)
                                    {
                                        <option value="@variant.Id">
                                            Size: @variant.Size - Màu: @variant.Color (@string.Format("{0:N0}", variant.Price) đ)
                                        </option>
                                    }
                                </select>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <span class="badge bg-warning text-dark rounded-0 w-100 py-2 fs-9">Sản phẩm tạm hết hàng</span>
                            </div>
                        }

                        <div class="mt-auto d-grid gap-2">
                            <button class="btn btn-outline-danger btn-sm fw-bold rounded-0 py-2 fs-8 btn-quick-view" data-id="@item.ProductId" data-action="add-to-cart">
                                <i class="bi bi-cart-plus me-1"></i> Thêm vào giỏ
                            </button>
                            <button class="btn btn-danger btn-sm fw-bold rounded-0 py-2 fs-8 text-uppercase btn-quick-view" data-id="@item.ProductId" data-action="buy-now">
                                Mua ngay
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="quickViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content rounded-0">
            <div id="quickViewModalBody">
            </div>
        </div>
    </div>
</div>

<style>
    .torano-product-card .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .torano-product-card:hover .card {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let selectedSize = null;
        let selectedColor = null;
        let quickViewSubmitting = false;

        function resetQuickViewState() {
            selectedSize = null;
            selectedColor = null;
            quickViewSubmitting = false;

            $('.btn-select-size')
                .removeClass('active-variant');

            $('.btn-select-color')
                .removeClass('active-variant');

            $('#selectedVariantId').val('');
            $('#quickViewQuantity').val(1).attr('max', 100);

            $('#btnConfirmAddToCart')
                .prop('disabled', true);

            $('#variantStockInfo').html(
                '<i class="bi bi-info-circle me-1"></i>' +
                'Vui lòng chọn size và màu'
            );

            $('#confirmButtonText').removeClass('d-none');
            $('#confirmButtonLoading').addClass('d-none');

            resetVariantDisplay();
        }

        function resetVariantDisplay() {
            const root = $('#quickViewRoot');

            if (!root.length) {
                return;
            }

            const defaultImage = root.data('default-image');
            const minPrice = Number(root.data('min-price')) || 0;

            if (defaultImage) {
                $('#quickViewImage').attr('src', defaultImage);
            }

            if (minPrice > 0) {
                $('#quickViewPrice').text(
                    'Từ ' +
                    minPrice.toLocaleString('vi-VN') +
                    ' đ'
                );
            }
            else {
                $('#quickViewPrice').html(
                    '<span class="text-muted fs-6 fw-normal">' +
                    'Chưa cập nhật giá' +
                    '</span>'
                );
            }
        }

        function checkMatchingVariant() {
            $('#selectedVariantId').val('');

            $('#btnConfirmAddToCart')
                .prop('disabled', true);

            if (!selectedSize || !selectedColor) {
                $('#variantStockInfo').html(
                    '<i class="bi bi-info-circle me-1"></i>' +
                    'Vui lòng chọn size và màu'
                );

                $('#quickViewQuantity')
                    .val(1)
                    .attr('max', 100);

                resetVariantDisplay();
                return;
            }

            const variants =
                Array.isArray(window.productVariants)
                    ? window.productVariants
                    : [];

            const matchedVariant = variants.find(function (variant) {
                return variant.size === selectedSize &&
                       variant.color === selectedColor;
            });

            if (!matchedVariant) {
                $('#variantStockInfo').html(
                    '<i class="bi bi-x-circle text-danger me-1"></i>' +
                    'Không có phiên bản phù hợp'
                );

                resetVariantDisplay();
                return;
            }

            $('#quickViewPrice').text(
                Number(matchedVariant.price)
                    .toLocaleString('vi-VN') +
                ' đ'
            );

            if (matchedVariant.variantImageUrl) {
                $('#quickViewImage').attr(
                    'src',
                    matchedVariant.variantImageUrl
                );
            }

            if (matchedVariant.quantity <= 0) {
                $('#variantStockInfo').html(
                    '<i class="bi bi-x-circle text-danger me-1"></i>' +
                    'Phiên bản này đã hết hàng'
                );

                $('#quickViewQuantity')
                    .val(1)
                    .attr('max', 1);

                return;
            }

            $('#selectedVariantId').val(matchedVariant.id);

            $('#quickViewQuantity')
                .val(1)
                .attr('max', matchedVariant.quantity);

            $('#variantStockInfo').html(
                '<i class="bi bi-check-circle text-success me-1"></i>' +
                'Còn lại: ' +
                matchedVariant.quantity +
                ' sản phẩm'
            );

            $('#btnConfirmAddToCart')
                .prop('disabled', false);
        }

        // Mở modal chọn biến thể.
        $(document).on('click', '.btn-quick-view', function () {
            const productId = $(this).data('id');
            const action = $(this).data('action');

            $.ajax({
                url: '/Home/GetQuickView/' + productId,
                type: 'GET',

                success: function (response) {
                    $('#quickViewModalBody').html(response);

                    selectedSize = null;
                    selectedColor = null;
                    quickViewSubmitting = false;

                    $('#currentAction').val(action);

                    $('#quickViewModal').modal('show');
                },

                error: function () {
                    Swal.fire(
                        'Lỗi hệ thống',
                        'Không thể kết nối đến máy chủ lúc này!',
                        'error'
                    );
                }
            });
        });

        // Chọn hoặc bỏ chọn size.
        $(document).on('click', '.btn-select-size', function () {
            const button = $(this);
            const clickedSize = button.data('size');

            // Bấm lại đúng size đang chọn thì bỏ chọn.
            if (selectedSize === clickedSize) {
                selectedSize = null;
                button.removeClass('active-variant');
            }
            else {
                $('.btn-select-size')
                    .removeClass('active-variant');

                button.addClass('active-variant');
                selectedSize = clickedSize;
            }

            checkMatchingVariant();
        });

        // Chọn hoặc bỏ chọn màu.
        $(document).on('click', '.btn-select-color', function () {
            const button = $(this);
            const clickedColor = button.data('color');

            // Bấm lại đúng màu đang chọn thì bỏ chọn.
            if (selectedColor === clickedColor) {
                selectedColor = null;
                button.removeClass('active-variant');
            }
            else {
                $('.btn-select-color')
                    .removeClass('active-variant');

                button.addClass('active-variant');
                selectedColor = clickedColor;
            }

            checkMatchingVariant();
        });

        // Kiểm tra số lượng khách nhập.
        $(document).on('input change', '#quickViewQuantity', function () {
            const quantityInput = $(this);

            let quantity =
                parseInt(quantityInput.val(), 10);

            const maxQuantity =
                parseInt(quantityInput.attr('max'), 10) || 100;

            if (Number.isNaN(quantity) || quantity < 1) {
                quantity = 1;
            }

            if (quantity > maxQuantity) {
                quantity = maxQuantity;

                Swal.fire({
                    icon: 'warning',
                    title: 'Không đủ tồn kho',
                    text:
                        'Sản phẩm hiện chỉ còn ' +
                        maxQuantity +
                        ' sản phẩm.',
                    timer: 1600,
                    showConfirmButton: false
                });
            }

            quantityInput.val(quantity);
        });

        // Thêm sản phẩm vào giỏ.
        $(document).on('click', '#btnConfirmAddToCart', function () {
            if (quickViewSubmitting) {
                return;
            }

            const variantId =
                $('#selectedVariantId').val();

            if (!variantId) {
                Swal.fire(
                    'Thông báo',
                    'Vui lòng chọn đầy đủ size và màu sắc.',
                    'warning'
                );

                return;
            }

            const quantity =
                parseInt($('#quickViewQuantity').val(), 10);

            if (Number.isNaN(quantity) || quantity < 1) {
                Swal.fire(
                    'Thông báo',
                    'Số lượng sản phẩm không hợp lệ.',
                    'warning'
                );

                return;
            }

            quickViewSubmitting = true;

            $('#btnConfirmAddToCart')
                .prop('disabled', true);

            $('#confirmButtonText')
                .addClass('d-none');

            $('#confirmButtonLoading')
                .removeClass('d-none');

            const formData =
                $('#frmQuickAddToCart').serialize();

            const actionType =
                $('#currentAction').val();

            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: formData,

                success: function (response) {
                    if (response.success) {
                        $('.badge-count').text(
                            response.newCount
                        );

                        $('#quickViewModal').modal('hide');

                        if (actionType === 'buy-now') {
                            window.location.href =
                                '/Cart/Index?buyNowId=' +
                                encodeURIComponent(
                                    response.cartItemId
                                );

                            return;
                        }

                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công',
                            text:
                                response.message ||
                                'Đã thêm vào giỏ hàng!',
                            timer: 1500,
                            showConfirmButton: false
                        });

                        return;
                    }

                    quickViewSubmitting = false;

                    $('#btnConfirmAddToCart')
                        .prop('disabled', false);

                    $('#confirmButtonText')
                        .removeClass('d-none');

                    $('#confirmButtonLoading')
                        .addClass('d-none');

                    if (response.redirectToLogin) {
                        window.location.href =
                            '/Identity/Account/Login?ReturnUrl=' +
                            encodeURIComponent(
                                window.location.pathname
                            );

                        return;
                    }

                    Swal.fire(
                        'Thông báo',
                        response.message || 'Có lỗi xảy ra!',
                        'warning'
                    );
                },

                error: function () {
                    quickViewSubmitting = false;

                    $('#btnConfirmAddToCart')
                        .prop('disabled', false);

                    $('#confirmButtonText')
                        .removeClass('d-none');

                    $('#confirmButtonLoading')
                        .addClass('d-none');

                    Swal.fire(
                        'Lỗi hệ thống',
                        'Không thể thêm sản phẩm vào giỏ hàng.',
                        'error'
                    );
                }
            });
        });

        // Reset trạng thái sau khi đóng modal.
        $('#quickViewModal').on('hidden.bs.modal', function () {
            resetQuickViewState();
            $('#quickViewModalBody').empty();
        });
    </script>
}