@model IEnumerable<hoangstore.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn - HoangStore";

    var cartItems = Model.ToList();
}

<div class="container py-4 pb-5">

    <!-- Anti-forgery token dùng cho toàn bộ AJAX POST -->
    <form id="cart-antiforgery-form" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
        <h3 class="serif-font text-uppercase fw-bold text-dark m-0 fs-5 fs-md-3">
            <i class="bi bi-bag-check-fill text-danger me-2"></i>
            Giỏ hàng
        </h3>

        <span id="cart-kind-count"
              class="badge bg-light text-secondary border ms-2 fs-9">
            @cartItems.Count sản phẩm
        </span>
    </div>

    @if (TempData["CartErrorMessage"] is string cartError)
    {
        <div class="alert alert-danger rounded-0"
             role="alert">
            @cartError
        </div>
    }

    @if (!cartItems.Any())
    {
        <div class="text-center py-5 border bg-light shadow-sm">
            <i class="bi bi-cart-x text-muted"
               style="font-size: 3rem;"></i>

            <p class="fs-6 mt-3 text-secondary">
                Giỏ hàng của bạn đang trống.
            </p>

            <a href="@Url.Action("Index", "Home")"
               class="btn btn-danger rounded-0 px-4 py-2 mt-2
                      text-uppercase fw-bold fs-8">
                Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row">

            <!-- Giao diện desktop -->
            <div class="col-12 mb-4 d-none d-md-block">
                <div class="card border-0 shadow-sm rounded-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">

                            <thead class="bg-light text-uppercase fs-9
                                          border-bottom fw-bold text-secondary">
                                <tr>
                                    <th scope="col"
                                        class="ps-4 py-3"
                                        style="width: 50px;">
                                        Chọn
                                    </th>

                                    <th scope="col" class="py-3">
                                        Sản phẩm
                                    </th>

                                    <th scope="col"
                                        class="py-3 text-center">
                                        Phân loại
                                    </th>

                                    <th scope="col"
                                        class="py-3 text-center"
                                        style="width: 130px;">
                                        Đơn giá
                                    </th>

                                    <th scope="col"
                                        class="py-3 text-center"
                                        style="width: 140px;">
                                        Số lượng
                                    </th>

                                    <th scope="col"
                                        class="py-3 text-end"
                                        style="width: 140px;">
                                        Số tiền
                                    </th>

                                    <th scope="col"
                                        class="py-3 text-center"
                                        style="width: 70px;">
                                    </th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in cartItems)
                                {
                                    var variant = item.ProductVariant;
                                    var product = variant?.Product;

                                    var imageUrl =
                                        !string.IsNullOrWhiteSpace(
                                            variant?.Variant_Image_Url)
                                            ? variant.Variant_Image_Url
                                            : product?.Image_Url;

                                    var productName =
                                        product?.Product_Name
                                        ?? "Sản phẩm không xác định";

                                    var itemPrice =
                                        variant?.Price ?? 0;

                                    var subTotal =
                                        itemPrice * item.Quantity;

                                    <tr class="cart-item-row"
                                        data-id="@item.Id"
                                        data-price="@itemPrice">

                                        <td class="ps-4 py-3">
                                            <input class="form-check-input rounded-0
                                                          cursor-pointer check-cart-item"
                                                   type="checkbox"
                                                   value="@item.Id" />
                                        </td>

                                        <td class="py-3">
                                            <div class="d-flex align-items-center">

                                                <img src="@(string.IsNullOrWhiteSpace(imageUrl)
                                                            ? "https://placehold.co/80x80"
                                                            : imageUrl)"
                                                     class="img-fluid border rounded-0
                                                            me-3 shadow-sm"
                                                     style="width: 65px;
                                                            height: 65px;
                                                            object-fit: cover;"
                                                     alt="@productName" />

                                                <h6 class="mb-0 fw-bold text-dark
                                                           text-uppercase fs-8 text-truncate"
                                                    style="max-width: 250px;"
                                                    title="@productName">
                                                    @productName
                                                </h6>
                                            </div>
                                        </td>

                                        <td class="py-3 text-center">
                                            <span class="badge bg-light text-dark
                                                         border rounded-0 fs-9
                                                         py-2 px-2 text-uppercase">
                                                Size: @variant?.Size /
                                                Màu: @variant?.Color
                                            </span>
                                        </td>

                                        <td class="py-3 text-center
                                                   text-secondary fs-8">
                                            @itemPrice.ToString("N0") đ
                                        </td>

                                        <td class="py-3 text-center">
                                            <div class="input-group input-group-sm
                                                        rounded-0 justify-content-center">

                                                <button class="btn btn-outline-secondary
                                                               btn-update-qty"
                                                        data-step="-1"
                                                        type="button"
                                                        aria-label="Giảm số lượng">
                                                    -
                                                </button>

                                                <input type="text"
                                                       class="form-control text-center
                                                              bg-white txt-quantity"
                                                       value="@item.Quantity"
                                                       readonly
                                                       style="max-width: 45px;
                                                              font-size: 12px;" />

                                                <button class="btn btn-outline-secondary
                                                               btn-update-qty"
                                                        data-step="1"
                                                        type="button"
                                                        aria-label="Tăng số lượng">
                                                    +
                                                </button>
                                            </div>
                                        </td>

                                        <td class="py-3 text-end fw-bold
                                                   text-danger fs-8 pe-3">
                                            <span class="item-subtotal"
                                                  data-subtotal="@subTotal">
                                                @subTotal.ToString("N0") đ
                                            </span>
                                        </td>

                                        <td class="py-3 text-center">
                                            <button class="btn btn-link link-secondary
                                                           p-0 btn-delete-single"
                                                    type="button"
                                                    data-id="@item.Id"
                                                    title="Xóa sản phẩm">

                                                <i class="bi bi-trash3 text-muted
                                                          hover-danger fs-6">
                                                </i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Giao diện mobile -->
            <div class="col-12 d-block d-md-none mb-5">
                @foreach (var item in cartItems)
                {
                    var variant = item.ProductVariant;
                    var product = variant?.Product;

                    var imageUrl =
                        !string.IsNullOrWhiteSpace(
                            variant?.Variant_Image_Url)
                            ? variant.Variant_Image_Url
                            : product?.Image_Url;

                    var productName =
                        product?.Product_Name
                        ?? "Sản phẩm không xác định";

                    var itemPrice =
                        variant?.Price ?? 0;

                    var subTotal =
                        itemPrice * item.Quantity;

                    <div class="card border-0 shadow-sm rounded-0
                                p-3 mb-3 mobile-cart-card cart-item-row"
                         data-id="@item.Id"
                         data-price="@itemPrice">

                        <div class="d-flex align-items-start gap-2">

                            <div class="pt-2">
                                <input class="form-check-input rounded-0
                                              cursor-pointer check-cart-item"
                                       type="checkbox"
                                       value="@item.Id" />
                            </div>

                            <img src="@(string.IsNullOrWhiteSpace(imageUrl)
                                        ? "https://placehold.co/80x80"
                                        : imageUrl)"
                                 class="border rounded-0"
                                 style="width: 75px;
                                        height: 75px;
                                        object-fit: cover;"
                                 alt="@productName" />

                            <div class="flex-grow-1 min-w-0">

                                <div class="d-flex justify-content-between
                                            align-items-start gap-1">

                                    <h6 class="fw-bold text-dark text-uppercase
                                               fs-9 text-truncate mb-1"
                                        style="max-width: 160px;">
                                        @productName
                                    </h6>

                                    <button class="btn p-0 text-muted
                                                   btn-delete-single"
                                            type="button"
                                            data-id="@item.Id"
                                            aria-label="Xóa sản phẩm">
                                        <i class="bi bi-trash3 fs-9"></i>
                                    </button>
                                </div>

                                <div class="text-muted fs-9
                                            text-uppercase mb-1">
                                    Mẫu: Size @variant?.Size -
                                    Màu @variant?.Color
                                </div>

                                <div class="text-danger fw-bold fs-8 mb-2">
                                    @itemPrice.ToString("N0") đ
                                </div>

                                <div class="d-flex justify-content-between
                                            align-items-center">

                                    <div class="input-group input-group-sm
                                                rounded-0"
                                         style="max-width: 100px;">

                                        <button class="btn btn-outline-secondary
                                                       btn-update-qty py-0 px-2"
                                                data-step="-1"
                                                type="button">
                                            -
                                        </button>

                                        <input type="text"
                                               class="form-control text-center
                                                      bg-white txt-quantity
                                                      py-0 px-1"
                                               value="@item.Quantity"
                                               readonly
                                               style="font-size: 11px;" />

                                        <button class="btn btn-outline-secondary
                                                       btn-update-qty py-0 px-2"
                                                data-step="1"
                                                type="button">
                                            +
                                        </button>
                                    </div>

                                    <div class="fw-bold text-danger fs-8">
                                        <span class="item-subtotal"
                                              data-subtotal="@subTotal">
                                            @subTotal.ToString("N0") đ
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Thanh công cụ phía dưới -->
            <div class="col-12 fixed-bottom bg-white border-top
                        shadow-lg py-2 px-3 checkout-sticky-bar">

                <div class="container p-0 d-flex flex-column flex-md-row
                            justify-content-between align-items-md-center gap-2">

                    <div class="d-flex align-items-center
                                justify-content-between
                                justify-content-md-start gap-3
                                border-bottom border-md-0
                                pb-2 pb-md-0 fs-8">

                        <div class="form-check m-0 d-flex
                                    align-items-center gap-2">

                            <input class="form-check-input rounded-0
                                          cursor-pointer"
                                   type="checkbox"
                                   id="check-all-cart" />

                            <label class="form-check-label text-dark
                                          cursor-pointer fw-bold fw-md-normal"
                                   for="check-all-cart"
                                   id="lbl-select-all-text">
                                Chọn tất cả (@cartItems.Count)
                            </label>
                        </div>

                        <button class="btn btn-link link-secondary
                                       p-0 text-decoration-none fs-9"
                                id="btn-delete-selected"
                                type="button">

                            <i class="bi bi-trash3 me-1"></i>
                            Xóa mục chọn
                        </button>
                    </div>

                    <div class="d-flex align-items-center
                                justify-content-between
                                justify-content-md-end
                                gap-3 gap-md-4">

                        <div class="text-end">
                            <span class="fs-9 text-muted d-none d-md-inline">
                                Tổng thanh toán
                                (<span id="selected-count">0</span> sản phẩm):
                            </span>

                            <span class="fs-9 text-muted d-inline d-md-none">
                                Tổng cộng
                                (<span id="selected-count-mb">0</span>):
                            </span>

                            <div class="fw-bold text-danger
                                        fs-5 fs-md-4"
                                 id="cart-final-price">
                                0 đ
                            </div>
                        </div>

                        <button type="button"
                                id="btn-proceed-checkout"
                                class="btn btn-danger rounded-0 fw-bold
                                       text-uppercase px-4 px-md-5
                                       py-2 py-md-3 fs-8 fs-md-7 shadow-sm"
                                disabled>
                            Mua hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    .fs-9 {
        font-size: 11px !important;
    }

    .fs-8 {
        font-size: 13px !important;
    }

    .hover-danger:hover {
        color: #dc3545 !important;
        transition: color 0.2s;
    }

    .cart-item-row-selected {
        background-color: #fffafb !important;
        border: 1px solid #ffccd3 !important;
    }

    .checkout-sticky-bar {
        z-index: 1030;
        box-shadow: 0 -5px 15px rgba(0, 0, 0, 0.08) !important;
    }

    .btn-update-qty:disabled {
        cursor: not-allowed;
        opacity: 0.6;
    }

    body {
        padding-bottom: 60px;
    }

    @@media (max-width: 767.98px) {
        body {
            padding-bottom: 110px;
        }
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            const antiForgeryToken =
                $('#cart-antiforgery-form input[name="__RequestVerificationToken"]').val();

            function showError(message) {
                Swal.fire({
                    icon: 'error',
                    title: 'Không thể thực hiện',
                    text: message || 'Có lỗi xảy ra.',
                    timer: 1800,
                    showConfirmButton: false
                });
            }

            function updateGlobalCartCount(newCount) {
                if (newCount !== undefined &&
                    newCount !== null) {
                    $('.badge-count').text(newCount);
                }
            }

            function getVisibleCartRows() {
                return $('.cart-item-row:visible');
            }

            function updateItemKindCount() {
                const count =
                    getVisibleCartRows().length;

                $('#cart-kind-count')
                    .text(count + ' sản phẩm');

                $('#lbl-select-all-text')
                    .text('Chọn tất cả (' + count + ')');
            }

            function calculateCartTotal() {
                let total = 0;
                let count = 0;

                $('.check-cart-item:checked:visible')
                    .each(function () {
                        const row =
                            $(this).closest('.cart-item-row');

                        const subTotal =
                            Number(
                                row.find('.item-subtotal')
                                    .data('subtotal')
                            ) || 0;

                        total += subTotal;
                        count++;
                    });

                $('#cart-final-price')
                    .text(
                        total.toLocaleString('vi-VN') +
                        ' đ'
                    );

                $('#selected-count').text(count);
                $('#selected-count-mb').text(count);

                $('#btn-proceed-checkout')
                    .prop('disabled', count === 0);
            }

            function updateCheckAllState() {
                const visibleCheckboxes =
                    $('.check-cart-item:visible');

                const checkedVisibleCheckboxes =
                    $('.check-cart-item:checked:visible');

                const allChecked =
                    visibleCheckboxes.length > 0 &&
                    visibleCheckboxes.length ===
                    checkedVisibleCheckboxes.length;

                $('#check-all-cart')
                    .prop('checked', allChecked);
            }

            function removeCartItemFromView(cartItemId) {
                $(
                    `.cart-item-row[data-id="${cartItemId}"]`
                ).remove();

                updateCheckAllState();
                updateItemKindCount();
                calculateCartTotal();

                if (getVisibleCartRows().length === 0) {
                    window.location.reload();
                }
            }

            // Chọn tất cả.
            $(document).on(
                'change',
                '#check-all-cart',
                function () {
                    const isChecked =
                        $(this).is(':checked');

                    $('.check-cart-item')
                        .prop('checked', isChecked);

                    $('.cart-item-row')
                        .toggleClass(
                            'cart-item-row-selected',
                            isChecked
                        );

                    calculateCartTotal();
                }
            );

            // Chọn từng sản phẩm.
            $(document).on(
                'change',
                '.check-cart-item',
                function () {
                    const cartItemId =
                        $(this).val();

                    const isChecked =
                        $(this).is(':checked');

                    $(
                        `.check-cart-item[value="${cartItemId}"]`
                    ).prop('checked', isChecked);

                    $(
                        `.cart-item-row[data-id="${cartItemId}"]`
                    ).toggleClass(
                        'cart-item-row-selected',
                        isChecked
                    );

                    updateCheckAllState();
                    calculateCartTotal();
                }
            );

            // Tăng hoặc giảm số lượng.
            $(document).on(
                'click',
                '.btn-update-qty',
                function () {
                    const button = $(this);

                    const row =
                        button.closest('.cart-item-row');

                    const cartItemId =
                        Number(row.data('id'));

                    const step =
                        Number(button.data('step'));

                    if (!cartItemId ||
                        (step !== 1 && step !== -1)) {
                        showError(
                            'Thông tin cập nhật số lượng không hợp lệ.'
                        );
                        return;
                    }

                    $(
                        `.cart-item-row[data-id="${cartItemId}"]`
                    )
                    .find('.btn-update-qty')
                    .prop('disabled', true);

                    $.ajax({
                        url: '/Cart/UpdateQuantity',
                        type: 'POST',

                        headers: {
                            'RequestVerificationToken':
                                antiForgeryToken
                        },

                        data: {
                            cartItemId: cartItemId,
                            step: step
                        },

                        success: function (response) {
                            if (!response.success) {
                                if (response.redirectToLogin) {
                                    window.location.href =
                                        '/Identity/Account/Login';

                                    return;
                                }

                                showError(response.message);
                                return;
                            }

                            const matchingRows =
                                $(
                                    `.cart-item-row[data-id="${cartItemId}"]`
                                );

                            matchingRows
                                .find('.txt-quantity')
                                .val(response.newQty);

                            matchingRows.each(function () {
                                const subtotalElement =
                                    $(this)
                                        .find('.item-subtotal');

                                subtotalElement
                                    .data(
                                        'subtotal',
                                        response.newSubTotal
                                    );

                                subtotalElement.text(
                                    Number(
                                        response.newSubTotal
                                    ).toLocaleString('vi-VN') +
                                    ' đ'
                                );
                            });

                            updateGlobalCartCount(
                                response.newCount
                            );

                            calculateCartTotal();
                        },

                        error: function () {
                            showError(
                                'Không thể cập nhật số lượng lúc này.'
                            );
                        },

                        complete: function () {
                            $(
                                `.cart-item-row[data-id="${cartItemId}"]`
                            )
                            .find('.btn-update-qty')
                            .prop('disabled', false);
                        }
                    });
                }
            );

            // Xóa một sản phẩm.
            $(document).on(
                'click',
                '.btn-delete-single',
                function () {
                    const cartItemId =
                        Number($(this).data('id'));

                    if (!cartItemId) {
                        showError(
                            'Sản phẩm cần xóa không hợp lệ.'
                        );
                        return;
                    }

                    Swal.fire({
                        title: 'Xác nhận xóa?',
                        text:
                            'Sản phẩm sẽ bị xóa khỏi giỏ hàng của bạn.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#dc3545',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'Xóa',
                        cancelButtonText: 'Hủy'
                    }).then(function (result) {
                        if (!result.isConfirmed) {
                            return;
                        }

                        $.ajax({
                            url: '/Cart/DeleteItem',
                            type: 'POST',

                            headers: {
                                'RequestVerificationToken':
                                    antiForgeryToken
                            },

                            data: {
                                cartItemId: cartItemId
                            },

                            success: function (response) {
                                if (!response.success) {
                                    if (response.redirectToLogin) {
                                        window.location.href =
                                            '/Identity/Account/Login';

                                        return;
                                    }

                                    showError(response.message);
                                    return;
                                }

                                updateGlobalCartCount(
                                    response.newCount
                                );

                                removeCartItemFromView(
                                    cartItemId
                                );
                            },

                            error: function () {
                                showError(
                                    'Không thể xóa sản phẩm lúc này.'
                                );
                            }
                        });
                    });
                }
            );

            // Xóa nhiều sản phẩm.
            $(document).on(
                'click',
                '#btn-delete-selected',
                function () {
                    const selectedIds = [];

                    $('.check-cart-item:checked:visible')
                        .each(function () {
                            const id =
                                Number($(this).val());

                            if (id > 0 &&
                                !selectedIds.includes(id)) {
                                selectedIds.push(id);
                            }
                        });

                    if (selectedIds.length === 0) {
                        Swal.fire({
                            icon: 'info',
                            title: 'Thông báo',
                            text:
                                'Vui lòng chọn ít nhất một sản phẩm để xóa.'
                        });

                        return;
                    }

                    Swal.fire({
                        title: 'Xóa các mục đã chọn?',
                        text:
                            `Bạn có chắc muốn xóa ` +
                            `${selectedIds.length} sản phẩm?`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#dc3545',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'Xóa',
                        cancelButtonText: 'Hủy'
                    }).then(function (result) {
                        if (!result.isConfirmed) {
                            return;
                        }

                        $.ajax({
                            url:
                                '/Cart/DeleteSelectedItems',

                            type: 'POST',

                            contentType:
                                'application/json; charset=utf-8',

                            headers: {
                                'RequestVerificationToken':
                                    antiForgeryToken
                            },

                            data:
                                JSON.stringify(selectedIds),

                            success: function (response) {
                                if (!response.success) {
                                    if (response.redirectToLogin) {
                                        window.location.href =
                                            '/Identity/Account/Login';

                                        return;
                                    }

                                    showError(response.message);
                                    return;
                                }

                                const deletedIds =
                                    response.deletedIds ||
                                    selectedIds;

                                deletedIds.forEach(
                                    function (id) {
                                        $(
                                            `.cart-item-row[data-id="${id}"]`
                                        ).remove();
                                    }
                                );

                                $('#check-all-cart')
                                    .prop('checked', false);

                                updateGlobalCartCount(
                                    response.newCount
                                );

                                updateItemKindCount();
                                calculateCartTotal();

                                if (
                                    getVisibleCartRows().length === 0
                                ) {
                                    window.location.reload();
                                }
                            },

                            error: function () {
                                showError(
                                    'Không thể xóa các sản phẩm lúc này.'
                                );
                            }
                        });
                    });
                }
            );

            // Tự chọn sản phẩm khi người dùng bấm Mua ngay.
            const urlParams =
                new URLSearchParams(
                    window.location.search
                );

            const buyNowId =
                urlParams.get('buyNowId');

            if (buyNowId &&
                Number(buyNowId) > 0) {
                $(
                    `.check-cart-item[value="${buyNowId}"]`
                ).prop('checked', true);

                $(
                    `.cart-item-row[data-id="${buyNowId}"]`
                ).addClass(
                    'cart-item-row-selected'
                );

                updateCheckAllState();
                calculateCartTotal();
            }

            // Chuyển sang Checkout.
            $(document).on(
                'click',
                '#btn-proceed-checkout',
                function () {
                    const selectedIds = [];

                    $('.check-cart-item:checked:visible')
                        .each(function () {
                            const id =
                                Number($(this).val());

                            if (id > 0 &&
                                !selectedIds.includes(id)) {
                                selectedIds.push(id);
                            }
                        });

                    if (selectedIds.length === 0) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Thông báo',
                            text:
                                'Vui lòng chọn ít nhất một sản phẩm để đặt hàng.'
                        });

                        return;
                    }

                    const itemIdsString =
                        selectedIds.join(',');

                    window.location.href =
                        '/Order/Checkout?itemIds=' +
                        encodeURIComponent(
                            itemIdsString
                        );
                }
            );

            calculateCartTotal();
        });
    </script>
}