@{
    ViewData["Title"] = "Kết quả thanh toán - HoangStore";
}

<div class="container mt-5 pt-5 text-center">
    <div class="card p-5 shadow-sm border border-light rounded-0 mx-auto" style="max-width: 600px; background-color: #fff;">

        @if (ViewBag.Status == "success")
        {
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 80px;"></i>
            </div>
            <h2 class="fw-bold text-success text-uppercase mb-3" style="letter-spacing: 1px;">Thanh toán thành công</h2>
            <p class="text-muted mb-4 fs-8">@ViewBag.Message</p>
            <div class="d-grid">
                <a href="/" class="btn btn-dark rounded-0 py-3 fw-bold text-uppercase tracking-wider fs-7">Tiếp tục mua sắm</a>
            </div>
        }
        else
        {
            <div class="mb-4">
                <i class="bi bi-x-circle-fill text-danger" style="font-size: 80px;"></i>
            </div>
            <h2 class="fw-bold text-danger text-uppercase mb-3" style="letter-spacing: 1px;">Giao dịch thất bại</h2>
            <p class="text-muted mb-4 fs-8">@ViewBag.Message</p>
            <div class="d-grid gap-2">
                <a href="/Cart" class="btn btn-outline-danger rounded-0 py-3 fw-bold text-uppercase tracking-wider fs-7">Quay lại giỏ hàng</a>
            </div>
        }

    </div>
</div>

<style>
    .fs-8 {
        font-size: 14px !important;
    }

    .fs-7 {
        font-size: 13px !important;
    }
</style>